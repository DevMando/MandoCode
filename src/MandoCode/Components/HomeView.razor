@using Spectre.Console

@*
    Static-info + connection-state + ready-state block extracted out of App.razor.
    Exists primarily so App.razor can hide the entire dynamic section with a single
    @if conditional during /setup — without component extraction, suppressing the
    block inline interacts awkwardly with the way RazorConsole's render anchor
    works, and the help table redraws stomp on the wizard's imperative output.
*@

<Rows>
    <Markup Content="@($"Project Root: {ProjectRoot}")" Background="Color.Black" />
    <Markup Content="@($"Runtime: .NET {RuntimeVersion}")" />
    <Markup Content="@($"Ollama Endpoint: {OllamaEndpoint}")" />
    <Markup Content="@($"Model: {ModelName}")" />

    @if (!ConnectionChecked)
    {
        <Markup Content="🔄 Connecting to Ollama..." />
    }
    else if (!IsConnected)
    {
        <Rows>
            <Markup Content="@($"Couldn't reach Ollama at {OllamaEndpoint}")" Foreground="Color.Yellow" />
            <Markup Content="Type /setup to retry onboarding, or /retry to reconnect." Foreground="Color.Grey" />
        </Rows>
    }
    else if (!string.IsNullOrEmpty(OnboardingStatus))
    {
        <Markup Content="@($"⏳ {OnboardingStatus}")" Foreground="Color.DeepSkyBlue1" />
    }
    else if (!string.IsNullOrEmpty(ModelWarning))
    {
        <Panel Border="@BoxBorder.Ascii" BorderColor="Color.Yellow">
            <Rows>
                <Markup Content="@ModelWarning" />
            </Rows>
        </Panel>
    }
    else
    {
        <Markup Content="✅ MandoCode is ready!" />
        <HelpDisplay />
        <Markup Content="@("Tip: reference files inline, e.g. What does @Program.cs do?")" />
        @if (!string.IsNullOrEmpty(UpdateNotice))
        {
            <Columns>
                @* Gold message + green command — the app's existing palette (gold values, green hints).
                   Markup escapes inline color tags, so two colors = two Markup elements side by side. *@
                <Markup Content="@UpdateNotice" Foreground="@(new Color(255, 200, 80))" />
                <Markup Content="@UpdateCommand" Foreground="Color.Green" />
            </Columns>
        }
    }
</Rows>

@code {
    [Parameter] public string ProjectRoot { get; set; } = "";
    [Parameter] public string RuntimeVersion { get; set; } = "";
    [Parameter] public string OllamaEndpoint { get; set; } = "";
    [Parameter] public string ModelName { get; set; } = "";
    [Parameter] public bool ConnectionChecked { get; set; }
    [Parameter] public bool IsConnected { get; set; }
    [Parameter] public string OnboardingStatus { get; set; } = "";
    [Parameter] public string? ModelWarning { get; set; }

    /// <summary>
    /// "A newer MandoCode is available" line (gold), set once the background update check
    /// resolves. Empty/null until then (or when up to date / opted out) so nothing renders.
    /// </summary>
    [Parameter] public string? UpdateNotice { get; set; }

    /// <summary>The upgrade command (`dotnet tool update -g MandoCode`), rendered green next to the notice.</summary>
    [Parameter] public string? UpdateCommand { get; set; }
}
