    private async Task HandleConfigCommandAsync()
    {
        AnsiConsole.WriteLine();
        var choice = AnsiConsole.Prompt(
            new SelectionPrompt<string>()
                .Title("Configuration Options:")
                .AddChoices(new[]
                {
                    "Run configuration wizard",
                    "View current configuration",
                    "Cancel"
                })
        );

        switch (choice)
        {
            case "Run configuration wizard":
                var updatedConfig = await ConfigurationWizard.RunAsync(
                    Config,
                    promptTextVdom: (title, placeholder, validate, initialValue) => WizardPromptTextAsync(title, placeholder, validate, initialValue));
                await AI.ReinitializeAsync(updatedConfig);
                AnsiConsole.Clear();
                AnsiConsole.WriteLine($"✓ Configuration updated! Now using model: {updatedConfig.GetEffectiveModelName()}\n");

                // Re-validate the model after config change
                var (isValid, errorMessage) = await AI.ValidateModelAsync();
                if (isValid)
                {
                    if (_modelError)
                    {
                        _modelError = false;
                        _modelWarning = null;
                        AnsiConsole.MarkupLine("[green]✓ Model validated successfully! You can now use MandoCode.[/]");
                        AnsiConsole.WriteLine();
                    }
                }
                else
                {
                    _modelError = true;
                    _modelWarning = errorMessage;
                    AnsiConsole.MarkupLine($"[yellow]Warning:[/] {errorMessage}");
                    AnsiConsole.MarkupLine("[dim]Pull the model or run /config again to select a different one.[/]");
                    AnsiConsole.WriteLine();
                }
                break;

            case "View current configuration":
                AnsiConsole.WriteLine();
                Config.Display();
                AnsiConsole.WriteLine();
                break;
        }
    }

    public void Dispose()
    {
        StopCancelKeyListener();
        StopMusicVisualizer();
        Spinner.Stop();

        // Detach event handlers registered in OnInitialized.
        // AIService is a singleton — if we don't unsubscribe, stale handlers linger
        // across App lifecycle and capture a disposed _requestCts via closure.
        if (_onFunctionInvokedHandler != null)
            AI.OnFunctionInvoked -= _onFunctionInvokedHandler;
        if (_onFunctionCompletedHandler != null)
            AI.OnFunctionCompleted -= _onFunctionCompletedHandler;
        if (_cancelKeyHandler != null)
            Console.CancelKeyPress -= _cancelKeyHandler;

        InstructionCoordinator.StateChanged -= OnInstructionStateChanged;

        // Clear the PlanHandoff callback so late-arriving propose_plan calls don't
        // hit a disposed App. AIService stays, but plan requests just return the
        // "not wired up" fallback from PlanHandoff.ProcessAsync.
        PlanHandoff.OnPlanRequested = null;

        var cts = Interlocked.Exchange(ref _requestCts, null);
        cts?.Dispose();
        MusicPlayer?.Dispose();
        ThemeService?.Dispose();
    }

