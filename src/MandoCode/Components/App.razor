    /// <summary>
    /// Shows a fuzzy-searchable picker of installed skills and returns the selected skill
    /// name (or null if the user cancels or no skills are installed). Uses Spectre's
    /// SelectionPrompt with EnableSearch so typing filters the list.
    /// </summary>
    private string? PromptForSkill()
    {
        var skills = Skills.GetAll();
        if (skills.Count == 0)
        {
            AnsiConsole.MarkupLine("[yellow]No skills installed.[/] Run [cyan]/skills[/] [yellow]for setup instructions.[/]");
            AnsiConsole.WriteLine();
            return null;
        }

        const string CancelChoice = "(cancel)";
        const string Separator = "  —  ";

        var entries = new List<string> { CancelChoice };
        foreach (var s in skills)
        {
            entries.Add(string.IsNullOrWhiteSpace(s.Description)
                ? s.Name
                : s.Name + Separator + s.Description);
        }

        string selected;
        try
        {
            selected = AnsiConsole.Prompt(
                new SelectionPrompt<string>()
                    .Title("[green]Select a skill to force:[/] [dim](type to filter)[/]")
                    .PageSize(10)
                    .MoreChoicesText("[dim](scroll for more)[/]")
                    .EnableSearch()
                    .AddChoices(entries)
            );
        }
        catch (Exception)
        {
            AnsiConsole.WriteLine();
            return null;
        }

        if (selected == CancelChoice)
        {
            AnsiConsole.WriteLine();
            return null;
        }

        var dashIdx = selected.IndexOf(Separator, StringComparison.Ordinal);
        return dashIdx > 0 ? selected[..dashIdx] : selected;
    }

    private async Task HandleForceSkillCommandAsync(string skillName)
    {
        AnsiConsole.WriteLine();

        if (string.IsNullOrWhiteSpace(skillName))
        {
            var picked = PromptForSkill();
            if (picked == null) return;
            skillName = picked;
        }

        var skill = Skills.GetByName(skillName);
        if (skill == null)
        {
            AnsiConsole.MarkupLine($"[red]No skill named[/] [cyan]{Spectre.Console.Markup.Escape(skillName)}[/] [red]is installed.[/]");
            AnsiConsole.MarkupLine("[dim]Run[/] [cyan]/skills[/] [dim]to see available skills.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        if (!_isConnected || _modelError)
        {
            AnsiConsole.MarkupLine("[yellow]Cannot run skill — no model is connected.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        AnsiConsole.MarkupLine($"[green]✓ Forcing skill:[/] [cyan]{Spectre.Console.Markup.Escape(skill.Name)}[/]");
        if (!string.IsNullOrWhiteSpace(skill.Description))
        {
            AnsiConsole.MarkupLine($"  [dim]{Spectre.Console.Markup.Escape(skill.Description)}[/]");
        }
        AnsiConsole.WriteLine();

        var forcedPrompt =
            $"[system: the user has explicitly forced skill '{skill.Name}' via /force-skill. " +
            $"Follow these instructions exactly for this turn, even if they differ from your defaults.]\n\n" +
            $"# Skill: {skill.Name}\n\n{skill.Body}";

        _messages.Add(new ChatMsg { Role = "user", Text = $"/force-skill {skill.Name}" });
        await ProcessDirectRequestAsync(forcedPrompt);
    }

    private async Task HandleMcpListCommandAsync()
    {
        AnsiConsole.WriteLine();

        if (!Config.EnableMcp)
        {
            AnsiConsole.MarkupLine("[yellow]MCP is disabled.[/] Enable with [cyan]mandocode --config set mcp true[/].");
            AnsiConsole.WriteLine();
            return;
        }

        if (Config.McpServers.Count == 0)
        {
            AnsiConsole.MarkupLine("[yellow]No MCP servers configured.[/]");
            AnsiConsole.MarkupLine($"[dim]Add servers to the 'mcpServers' block in {Spectre.Console.Markup.Escape(MandoCodeConfig.GetDefaultConfigPath())}[/]");
            AnsiConsole.WriteLine();
            return;
        }

        var table = new Table().Border(TableBorder.Rounded);
        table.AddColumn("Server");
        table.AddColumn("Transport");
        table.AddColumn("Status");
        table.AddColumn("Tools");

        foreach (var (name, serverCfg) in Config.McpServers)
        {
            var transport = serverCfg.IsHttp ? "http" : "stdio";
            string status;
            string toolCount = "-";

            if (serverCfg.Disabled)
            {
                status = "[dim]disabled[/]";
            }
            else if (McpManager.ActiveClients.TryGetValue(name, out var client))
            {
                status = "[green]connected[/]";
                try
                {
                    var tools = await client.ListToolsAsync();
                    toolCount = tools.Count.ToString();
                }
                catch { toolCount = "?"; }
            }
            else if (McpManager.StartupErrors.TryGetValue(name, out var err))
            {
                status = $"[red]failed:[/] [dim]{Spectre.Console.Markup.Escape(err)}[/]";
            }
            else
            {
                status = "[yellow]not started[/]";
            }

            table.AddRow(Spectre.Console.Markup.Escape(name), transport, status, toolCount);
        }

        AnsiConsole.Write(table);
        AnsiConsole.WriteLine();
    }

    private async Task HandleMcpReloadCommandAsync()
    {
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[dim]Reloading MCP servers...[/]");

        McpGate.ResetSession();
        await McpManager.ReloadAsync();
        // Full kernel rebuild so previously-registered mcp_* plugins are dropped before re-attaching.
        await AI.ReinitializeAsync(Config);

        var active = McpManager.ActiveClients.Count;
        var failed = McpManager.StartupErrors.Count;
        AnsiConsole.MarkupLine(failed == 0
            ? $"[green]MCP reloaded: {active} server(s) connected.[/]"
            : $"[yellow]MCP reloaded: {active} connected, {failed} failed.[/]");
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// Removes a server from config (and teardown of its connection) after a confirm.
    /// If <paramref name="serverArg"/> is empty, lists configured servers and aborts.
    /// </summary>
    private async Task HandleMcpRemoveCommandAsync(string serverArg)
    {
        AnsiConsole.WriteLine();

        if (string.IsNullOrWhiteSpace(serverArg))
        {
            AnsiConsole.MarkupLine("[yellow]Usage:[/] /mcp remove <name>");
            if (Config.McpServers.Count > 0)
            {
                AnsiConsole.MarkupLine($"[dim]Configured: {string.Join(", ", Config.McpServers.Keys)}[/]");
            }
            AnsiConsole.WriteLine();
            return;
        }

        if (!Config.McpServers.ContainsKey(serverArg))
        {
            AnsiConsole.MarkupLine($"[yellow]No server named '{Spectre.Console.Markup.Escape(serverArg)}' is configured.[/]");
            if (Config.McpServers.Count > 0)
            {
                AnsiConsole.MarkupLine($"[dim]Configured: {string.Join(", ", Config.McpServers.Keys)}[/]");
            }
            AnsiConsole.WriteLine();
            return;
        }

        var confirmed = await WizardConfirmAsync($"Remove MCP server '{serverArg}'?", defaultYes: false);
        if (!confirmed)
        {
            AnsiConsole.MarkupLine("[dim]Cancelled.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        Config.McpServers.Remove(serverArg);
        try { Config.Save(); }
        catch (Exception ex)
        {
            AnsiConsole.MarkupLine($"[red]Failed to save config:[/] {Spectre.Console.Markup.Escape(ex.Message)}");
            AnsiConsole.WriteLine();
            return;
        }

        AnsiConsole.MarkupLine($"[dim]Removed '{Spectre.Console.Markup.Escape(serverArg)}'. Reloading...[/]");
        McpGate.ResetSession();
        await McpManager.ReloadAsync();
        await AI.ReinitializeAsync(Config);
        AnsiConsole.MarkupLine($"[green]✓ '{Spectre.Console.Markup.Escape(serverArg)}' removed.[/]");
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// Lists tools exposed by one or all connected MCP servers, with descriptions.
    /// If <paramref name="serverFilter"/> is null, iterates every active server.
    /// </summary>
    private async Task HandleMcpToolsCommandAsync(string? serverFilter)
    {
        AnsiConsole.WriteLine();

        if (McpManager.ActiveClients.Count == 0)
        {
            AnsiConsole.MarkupLine("[yellow]No MCP servers are connected.[/]");
            AnsiConsole.MarkupLine("[dim]Type /mcp for status, or /mcp add to configure one.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        if (serverFilter != null && !McpManager.ActiveClients.ContainsKey(serverFilter))
        {
            AnsiConsole.MarkupLine($"[yellow]Server '{Spectre.Console.Markup.Escape(serverFilter)}' is not connected.[/]");
            AnsiConsole.MarkupLine($"[dim]Connected: {string.Join(", ", McpManager.ActiveClients.Keys)}[/]");
            AnsiConsole.WriteLine();
            return;
        }

        var clients = serverFilter != null
            ? new[] { (serverFilter, McpManager.ActiveClients[serverFilter]) }
            : McpManager.ActiveClients.Select(kv => (kv.Key, kv.Value)).ToArray();

        foreach (var (serverName, client) in clients)
        {
            IList<ModelContextProtocol.Client.McpClientTool> tools;
            try
            {
                tools = await client.ListToolsAsync();
            }
            catch (Exception ex)
            {
                AnsiConsole.MarkupLine($"[red]{Spectre.Console.Markup.Escape(serverName)}:[/] [dim]{Spectre.Console.Markup.Escape(ex.Message)}[/]");
                continue;
            }

            var table = new Table().Border(TableBorder.Rounded).Title($"[cyan]{Spectre.Console.Markup.Escape(serverName)}[/] [dim]({tools.Count} tool{(tools.Count == 1 ? "" : "s")})[/]");
            table.AddColumn("Tool");
            table.AddColumn("Description");
            foreach (var t in tools)
            {
                var desc = string.IsNullOrWhiteSpace(t.Description) ? "[dim](no description)[/]" : Spectre.Console.Markup.Escape(t.Description);
                table.AddRow(Spectre.Console.Markup.Escape(t.Name), desc);
            }
            AnsiConsole.Write(table);
        }
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// Interactive wizard for adding a new MCP server. Writes straight to the live
    /// <see cref="Config"/> singleton, persists to disk via <c>Config.Save()</c>, then
    /// reuses the /mcp-reload path so the new server connects without an app restart.
    /// All prompts flow through RazorConsole's TextInput / Select components — no
    /// Spectre TextPrompt / SelectionPrompt — to avoid the Console.ReadKey vs VDOM
    /// render-loop conflict that swallows keystrokes on Windows.
    /// </summary>
    private async Task HandleMcpAddCommandAsync()
    {
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[cyan bold]Add an MCP server[/]");
        AnsiConsole.MarkupLine("[dim]Ctrl+C at any prompt to cancel.[/]");
        AnsiConsole.WriteLine();

        var rawName = await WizardPromptTextAsync(
            "Server name (e.g. solana):",
            placeholder: "short identifier, no spaces",
            validate: n => string.IsNullOrWhiteSpace(n)
                ? "Name cannot be empty"
                : n.Contains(' ')
                    ? "Name cannot contain spaces"
                    : null);

        // Normalize to lowercase — MCP servers are referenced by name in tool prefixes
        // (mcp_<server>) and in /mcp-reload etc. Keeping case sensitivity just leaves
        // room for hard-to-spot "Solana" vs "solana" mistakes.
        var name = rawName.ToLowerInvariant();

        // Duplicate-name check — offer overwrite rather than silently clobber.
        if (Config.McpServers.ContainsKey(name))
        {
            var overwrite = await WizardConfirmAsync($"'{name}' already exists. Overwrite?", defaultYes: false);
            if (!overwrite)
            {
                AnsiConsole.MarkupLine("[dim]Cancelled.[/]");
                AnsiConsole.WriteLine();
                return;
            }
        }

        var transport = await WizardPromptSelectAsync("Transport:", "http (remote server)", "stdio (local process)");
        var isHttp = transport.StartsWith("http");

        var server = new McpServerConfig();

        if (isHttp)
        {
            server.Url = await WizardPromptTextAsync(
                "URL (e.g. https://mcp.solana.com/mcp):",
                placeholder: "https://...",
                validate: u => !Uri.TryCreate(u, UriKind.Absolute, out _)
                    ? "Must be an absolute URL"
                    : null);
            server.Transport = "http";

            if (await WizardConfirmAsync("Add custom headers (e.g. Authorization)?", defaultYes: false))
            {
                await CollectKeyValuePairsVdomAsync("Header", server.Headers);
            }
        }
        else
        {
            server.Command = await WizardPromptTextAsync(
                "Command (e.g. npx, uvx, binary path):",
                placeholder: "executable",
                validate: c => string.IsNullOrWhiteSpace(c) ? "Command cannot be empty" : null);

            var argsLine = await WizardPromptTextAsync(
                "Arguments (space-separated, leave empty for none):",
                placeholder: "-y @scope/server-foo",
                validate: null);
            if (!string.IsNullOrWhiteSpace(argsLine))
            {
                // Split on whitespace, preserve quoted segments.
                server.Args = ParseShellLikeArgs(argsLine);
            }

            if (await WizardConfirmAsync("Add environment variables?", defaultYes: false))
            {
                await CollectKeyValuePairsVdomAsync("Environment variable", server.Env);
            }
        }

        // Preview — show the user exactly what'll be written before we touch the disk.
        // We hand-build the object graph so empty collections / nulls don't clutter the
        // preview ("command": null, "args": [], "env": {}).
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[cyan]Preview:[/]");
        var previewWrapper = new Dictionary<string, object> { [name] = BuildPreviewDict(server) };
        var previewJson = System.Text.Json.JsonSerializer.Serialize(previewWrapper,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        AnsiConsole.WriteLine(previewJson);
        AnsiConsole.WriteLine();

        if (!await WizardConfirmAsync("Save and reload?", defaultYes: true))
        {
            AnsiConsole.MarkupLine("[dim]Cancelled — nothing written.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        Config.McpServers[name] = server;
        try
        {
            Config.Save();
        }
        catch (Exception ex)
        {
            AnsiConsole.MarkupLine($"[red]Failed to save config:[/] {Spectre.Console.Markup.Escape(ex.Message)}");
            AnsiConsole.WriteLine();
            Config.McpServers.Remove(name);
            return;
        }

        AnsiConsole.MarkupLine($"[dim]Saved. Connecting to '{Spectre.Console.Markup.Escape(name)}'...[/]");
        McpGate.ResetSession();
        await McpManager.ReloadAsync();
        await AI.ReinitializeAsync(Config);

        if (McpManager.ActiveClients.TryGetValue(name, out var client))
        {
            try
            {
                var tools = await client.ListToolsAsync();
                AnsiConsole.MarkupLine($"[green]✓ Server '{Spectre.Console.Markup.Escape(name)}' connected ({tools.Count} tool(s)).[/]");
            }
            catch
            {
                AnsiConsole.MarkupLine($"[green]✓ Server '{Spectre.Console.Markup.Escape(name)}' connected.[/]");
            }
        }
        else if (McpManager.StartupErrors.TryGetValue(name, out var err))
        {
            AnsiConsole.MarkupLine($"[yellow]Server saved but failed to connect:[/] [dim]{Spectre.Console.Markup.Escape(err)}[/]");
            AnsiConsole.MarkupLine($"[dim]Edit {Spectre.Console.Markup.Escape(MandoCodeConfig.GetDefaultConfigPath())} and run /mcp-reload to retry.[/]");
        }
        else
        {
            AnsiConsole.MarkupLine($"[yellow]Server saved but did not appear in active clients. Type /mcp for details.[/]");
        }
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// VDOM version of the key/value collector — used by the headers and env-vars steps
    /// of the /mcp add wizard. Loops until the user submits an empty name.
    /// </summary>
    private async Task CollectKeyValuePairsVdomAsync(string label, Dictionary<string, string> into)
    {
        AnsiConsole.MarkupLine($"[dim]Enter one {label.ToLower()} at a time. Leave the name empty to finish.[/]");
        while (true)
        {
            var key = await WizardPromptTextAsync($"{label} name (empty to finish):", placeholder: "", validate: null);
            if (string.IsNullOrWhiteSpace(key)) break;

            var value = await WizardPromptTextAsync($"{label} value:", placeholder: "", validate: null);
            into[key] = value;
        }
    }

    /// <summary>
    /// Build the preview dict for /mcp add, skipping null / empty fields so the JSON
    /// block in the prompt stays tight. The full object with defaults still hits disk via
    /// Config.Save(); this is purely display shaping.
    /// </summary>
    private static Dictionary<string, object> BuildPreviewDict(McpServerConfig server)
    {
        var dict = new Dictionary<string, object>();
        if (!string.IsNullOrWhiteSpace(server.Command)) dict["command"] = server.Command!;
        if (server.Args.Count > 0) dict["args"] = server.Args;
        if (server.Env.Count > 0) dict["env"] = server.Env;
        if (!string.IsNullOrWhiteSpace(server.Url)) dict["url"] = server.Url!;
        if (!string.IsNullOrWhiteSpace(server.Transport)) dict["transport"] = server.Transport!;
        if (server.Headers.Count > 0) dict["headers"] = server.Headers;
        if (server.Disabled) dict["disabled"] = server.Disabled;
        if (server.AutoApprove.Count > 0) dict["autoApprove"] = server.AutoApprove;
        return dict;
    }

    /// <summary>
    /// Split a command-line-style argument string, honoring double-quoted segments so users
    /// can include paths with spaces. Not a full shell parser — no escapes, no single quotes —
    /// which matches how Claude Desktop / Cursor treat these args (plain JSON array of strings).
    /// </summary>
    private static List<string> ParseShellLikeArgs(string input)
    {
        var result = new List<string>();
        var current = new System.Text.StringBuilder();
        bool inQuotes = false;
        foreach (var ch in input)
        {
            if (ch == '"') { inQuotes = !inQuotes; continue; }
            if (ch == ' ' && !inQuotes)
            {
                if (current.Length > 0) { result.Add(current.ToString()); current.Clear(); }
                continue;
            }
            current.Append(ch);
        }
        if (current.Length > 0) result.Add(current.ToString());
        return result;
    }

