    /// <summary>
    /// Bound to the wizard's Select.ValueChanged — fires when the user presses Enter on a
    /// highlighted option (RazorConsole's Select uses Enter as the commit signal).
    /// </summary>
    private void HandleWizardSelectSubmit(string value)
    {
        _wizardSelectValue = value;
        _wizardSelectTcs?.TrySetResult(value);
    }

    /// <summary>
    /// Show a single-line text prompt rendered through RazorConsole's TextInput component.
    /// Avoids Spectre's TextPrompt entirely so there's no Console.ReadLine vs VDOM render-loop
    /// conflict. Optional <paramref name="validate"/> returns null on success, an error message
    /// on failure — failure prints the error and re-prompts.
    /// </summary>
    private async Task<string> WizardPromptTextAsync(string title, string placeholder = "", Func<string, string?>? validate = null, string? initialValue = null)
    {
        while (true)
        {
            // Render the title as a separate scrollback line above the input box so it
            // persists after the input is dismissed.
            AnsiConsole.MarkupLine($"[cyan]{Spectre.Console.Markup.Escape(title)}[/]");

            // Pre-fill with initialValue when provided (e.g., default URL for endpoint
            // entry — user can press Enter to accept or edit in place). Empty otherwise,
            // and the placeholder hint shows in greyed text until the user types.
            _wizardInputValue = initialValue ?? "";
            _wizardInputPlaceholder = placeholder;
            _wizardInputTcs = new TaskCompletionSource<string>();
            _showWizardInput = true;
            _showPrompt = false;
            await InvokeAsync(StateHasChanged);

            var result = await _wizardInputTcs.Task;

            _showWizardInput = false;
            await InvokeAsync(StateHasChanged);
            // Brief wait so the VDOM tears down the input before we Console.Write the gold echo.
            await Task.Delay(50);

            if (validate != null)
            {
                var error = validate(result);
                if (error != null)
                {
                    AnsiConsole.MarkupLine($"[red]{Spectre.Console.Markup.Escape(error)}[/]");
                    AnsiConsole.WriteLine();
                    continue;
                }
            }

            // Persist the answer in scrollback (matches the > gold echo pattern in the main loop).
            Console.WriteLine($"\u001b[38;2;255;200;80m> {result}\u001b[0m");
            return result;
        }
    }

    /// <summary>
    /// Show a list of options rendered through RazorConsole's Select component. User navigates
    /// with arrow keys and commits with Enter. Returns the selected option string.
    /// </summary>
    private async Task<string> WizardPromptSelectAsync(string title, params string[] options)
    {
        if (options.Length == 0) throw new ArgumentException("At least one option required", nameof(options));

        AnsiConsole.MarkupLine($"[cyan]{Spectre.Console.Markup.Escape(title)}[/]");

        _wizardSelectOptions = options;
        _wizardSelectValue = options[0];
        _wizardSelectTcs = new TaskCompletionSource<string>();
        _showWizardSelect = true;
        _showPrompt = false;
        await InvokeAsync(StateHasChanged);

        var result = await _wizardSelectTcs.Task;

        _showWizardSelect = false;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);

        Console.WriteLine($"\u001b[38;2;255;200;80m> {result}\u001b[0m");
        return result;
    }

    /// <summary>
    /// Convenience: yes/no confirm rendered as a Select with two options. Used by wizards
    /// instead of <c>AnsiConsole.Confirm</c> so the entire flow stays inside the VDOM render
    /// pipeline.
    /// </summary>
    private async Task<bool> WizardConfirmAsync(string title, bool defaultYes = false)
    {
        var yes = "Yes";
        var no = "No";
        var options = defaultYes ? new[] { yes, no } : new[] { no, yes };
        var picked = await WizardPromptSelectAsync(title, options);
        return picked == yes;
    }

    /// <summary>
    /// Called by PromptInput when @ or / triggers autocomplete.
    /// Hides VDOM, runs imperative autocomplete (Console.ReadKey loop),
    /// then completes with the full input line.
    /// </summary>
    private async Task HandleAutocompleteRequested(string currentInput)
    {
        if (_autocompleteActive) return;
        _autocompleteActive = true;

        try
        {
            // 1. Hide PromptInput so Console.ReadKey doesn't conflict with VDOM
            _showPrompt = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(100); // Wait for VDOM repaint

            // 2. Run imperative autocomplete on a background thread
            //    Console.ReadKey blocks, so we use Task.Run.
            //    ContinueAutocomplete() picks up from the current state machine state
            //    (already has "@" or "/..." from PromptInput's HandleInput) — no reset.
            //    Returns null if user erased the trigger (@ or /) — go back to VDOM.
            var result = await Task.Run(() => CommandAutocomplete.ContinueAutocomplete());

            // Drain any buffered keystrokes typed while the prompt was hidden
            var resumeText = result ?? StateMachine.State.InputText;
            var buffered = DrainConsoleKeyBuffer();
            if (!string.IsNullOrEmpty(buffered))
            {
                resumeText += buffered;
                StateMachine.UpdateText(resumeText);
            }

            _promptInitialValue = resumeText;
        }
        finally
        {
            _autocompleteActive = false;
            _showPrompt = true;
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Shows the VDOM PromptInput component and awaits user submission.
    /// Returns the submitted text without blocking the Blazor render thread.
    /// The prompt stays visible but disabled during processing — this avoids
    /// border artifacts that occur when the component is removed from the VDOM tree.
    /// </summary>
    private async Task<string> WaitForVdomInputAsync()
    {
        _inputTcs = new TaskCompletionSource<string>();
        _promptInitialValue = "";
        _showPrompt = true;
        _isProcessing = false;
        await InvokeAsync(StateHasChanged);

        var input = await _inputTcs.Task;

        // Hide the prompt during processing
        _showPrompt = false;
        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        // Wait for the VDOM repaint to finish removing the PromptInput
        // before any imperative Console.Write calls
        await Task.Delay(100);

        return input;
    }

    // Total-budget cap across all @file/@dir expansions in one message. Individual files
    // are capped at 10k chars each, but many @refs combined can still blow the context
    // before the chat call even starts. At this size (~60k chars ≈ 15k tokens) we stop
    // expanding further references and append a notice.
    private const int MaxFileReferenceBudgetChars = 60_000;

    private string ProcessFileReferences(string input)
    {
        var pattern = @"@([\w.\-/\\]+[\w.])";
        var matches = Regex.Matches(input, pattern);

        if (matches.Count == 0)
            return input;

        var contextBlocks = new System.Text.StringBuilder();
        var referencedFiles = new HashSet<string>();
        int totalExpansionChars = 0;
        int skippedForBudget = 0;

        foreach (Match match in matches)
        {
            var filePath = match.Groups[1].Value;

            // Skip duplicates
            if (!referencedFiles.Add(filePath))
                continue;

            // Total-budget check — stop expanding once we've accumulated enough context.
            if (totalExpansionChars >= MaxFileReferenceBudgetChars)
            {
                skippedForBudget++;
                continue;
            }

            var content = FileProvider.ReadFileContent(filePath);
            if (content != null)
            {
                // Truncate files over 10,000 chars
                if (content.Length > 10_000)
                    content = content.Substring(0, 10_000) + "\n... [truncated]";

                contextBlocks.AppendLine($"File: {filePath}");
                contextBlocks.AppendLine("```");
                contextBlocks.AppendLine(content);
                contextBlocks.AppendLine("```");
                contextBlocks.AppendLine();
                totalExpansionChars += content.Length;

                // Track estimated tokens for @file references
                if (Config.EnableTokenTracking)
                {
                    TokenTracker.RecordEstimatedUsage(content.Length, $"@{filePath}");
                }

                // Show consistent operation display for @file reads
                var lineCount = content.Split('\n').Length;
                var readDisplay = new OperationDisplayEvent
                {
                    OperationType = "Read",
                    FilePath = filePath,
                    LineCount = lineCount
                };
                OperationRenderer.Render(readDisplay);
            }
            else
            {
                // Check if this is a directory reference
                var dirListing = FileProvider.GetDirectoryListing(filePath);
                if (dirListing != null)
                {
                    // Dir listings can be huge for big projects — cap at 4k chars per reference.
                    if (dirListing.Length > 4_000)
                        dirListing = dirListing.Substring(0, 4_000) + "\n... [truncated]";

                    contextBlocks.AppendLine($"Directory: {filePath}/");
                    contextBlocks.AppendLine("Contents:");
                    contextBlocks.AppendLine(dirListing);
                    contextBlocks.AppendLine();
                    totalExpansionChars += dirListing.Length;

                    AnsiConsole.MarkupLine($"[dim][[Directory]][/] [cyan]{Spectre.Console.Markup.Escape(filePath)}/[/]");
                }
                else
                {
                    AnsiConsole.MarkupLine($"[dim][[Not found]][/] [yellow]{Spectre.Console.Markup.Escape(filePath)}[/]");
                }
            }
        }

        if (contextBlocks.Length == 0)
            return input;

        if (skippedForBudget > 0)
        {
            contextBlocks.AppendLine($"[Note: {skippedForBudget} additional @reference(s) were skipped — the total expansion budget of {MaxFileReferenceBudgetChars:N0} chars was reached. Re-reference specific files in follow-up messages if needed.]");
            contextBlocks.AppendLine();
            AnsiConsole.MarkupLine($"[yellow][[Skipped]][/] [dim]{skippedForBudget} @reference(s) beyond expansion budget ({MaxFileReferenceBudgetChars:N0} chars)[/]");
        }

        var fullContext = new System.Text.StringBuilder();
        fullContext.AppendLine("--- Referenced Files ---");
        fullContext.Append(contextBlocks);
        fullContext.AppendLine("---");
        fullContext.AppendLine();
        fullContext.Append(input);

        return fullContext.ToString();
    }

    private static string DrainConsoleKeyBuffer()
    {
        if (!Console.KeyAvailable)
            return string.Empty;

        var chars = new List<char>();
        while (Console.KeyAvailable)
        {
            var key = Console.ReadKey(intercept: true);

            if (key.Key is ConsoleKey.Enter or ConsoleKey.Escape)
                continue;

            if (!char.IsControl(key.KeyChar))
                chars.Add(key.KeyChar);
        }

        return chars.Count > 0 ? new string(chars.ToArray()) : string.Empty;
    }

    private void ShowOfflineGuidance()
    {
        var endpoint = Spectre.Console.Markup.Escape(Config.OllamaEndpoint);
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine($"[yellow]MandoCode can't reach Ollama at {endpoint}.[/]");
        AnsiConsole.MarkupLine("[dim]Start 'ollama serve', pull a model, then type /retry to reconnect — or /setup to walk through setup again.[/]");
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// Starts a background task that listens for Escape key presses and cancels _requestCts.
    /// Call StopCancelKeyListener() when the AI request completes to clean up.
    /// </summary>
    private void StartCancelKeyListener()
    {
        var listenerCts = new CancellationTokenSource();
        _keyListenerCts = listenerCts;

        Task.Run(async () =>
        {
            try
            {
                while (!listenerCts.Token.IsCancellationRequested)
                {
                    // Skip ReadKey while a Spectre prompt owns the console — otherwise
                    // we race the prompt's own reader and silently drop arrow keys.
                    if (!KeyCoordinator.Suppressed && Console.KeyAvailable)
                    {
                        var key = Console.ReadKey(intercept: true);
                        if (key.Key == ConsoleKey.Escape)
                        {
                            var cts = _requestCts;
                            if (cts != null && !cts.IsCancellationRequested)
                            {
                                cts.Cancel();
                            }
                            break;
                        }
                    }
                    await Task.Delay(50, listenerCts.Token);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    /// <summary>
    /// Stops the background Escape key listener.
    /// </summary>
    private void StopCancelKeyListener()
    {
        var cts = Interlocked.Exchange(ref _keyListenerCts, null);
        if (cts != null)
        {
            cts.Cancel();
            cts.Dispose();
        }
    }

    private async Task ProcessDirectRequestAsync(string input)
    {
        // Reset operation tracking for the new request
        _recentReadCount = 0;
        _recentReadFiles.Clear();
        _lastOperationType = null;

        AnsiConsole.WriteLine();

        _requestCts = new CancellationTokenSource();
        var token = _requestCts.Token;
        StartCancelKeyListener();

        try
        {
            var receivedFirstChunk = false;
            var enumerator = AI.ChatStreamAsync(input, token).GetAsyncEnumerator(token);

            try
            {
                // Show our controllable spinner while waiting for first chunk
                // This spinner can be stopped by HandleDiffApproval when it needs user input
                Spinner.Start("Thinking...");

                if (await enumerator.MoveNextAsync())
                {
                    receivedFirstChunk = true;
                }

                Spinner.Stop();

                if (!receivedFirstChunk)
                {
                    AnsiConsole.MarkupLine("[yellow]No response from model. The request may have exceeded the model's context window.[/]");
                    AnsiConsole.MarkupLine("[dim]Try a smaller request, or switch to a model with a larger context window via /config.[/]");
                }

                // Buffer all chunks, then render as rich markdown
                if (receivedFirstChunk)
                {
                    var responseBuffer = new System.Text.StringBuilder();
                    var lineBuffer = new System.Text.StringBuilder();
                    var showSpinnerBeforeNextChunk = false;

                    void AccumulateChunk(string chunk)
                    {
                        responseBuffer.Append(chunk);
                        foreach (char c in chunk)
                        {
                            if (c == '\n')
                            {
                                if (lineBuffer.ToString().Contains('\u2699'))
                                    showSpinnerBeforeNextChunk = true;
                                lineBuffer.Clear();
                            }
                            else if (c != '\r')
                            {
                                lineBuffer.Append(c);
                            }
                        }
                    }

                    AccumulateChunk(enumerator.Current);

                    var hasMore = true;
                    while (hasMore)
                    {
                        if (showSpinnerBeforeNextChunk)
                        {
                            showSpinnerBeforeNextChunk = false;
                            Spinner.Start();
                            hasMore = await enumerator.MoveNextAsync();
                            Spinner.Stop();
                        }
                        else
                        {
                            hasMore = await enumerator.MoveNextAsync();
                        }

                        if (hasMore)
                            AccumulateChunk(enumerator.Current);
                    }

                    // Render the complete response as rich markdown
                    var responseText = responseBuffer.ToString().Trim();
                    if (string.IsNullOrEmpty(responseText))
                    {
                        AnsiConsole.MarkupLine("[yellow]Model returned an empty response. The context may be too large for this model.[/]");
                        AnsiConsole.MarkupLine("[dim]Try a smaller request, or switch to a model with a larger context window via /config.[/]");
                    }
                    else
                    {
                        _lastAiResponse = responseText;

                        try
                        {
                            AnsiConsole.MarkupLine("[green]MandoCode:[/]");

                            // Guard against rendering hangs on malformed/huge responses.
                            // Large responses with many tables/code blocks can take 10+ seconds to render.
                            var renderTask = Task.Run(() =>
                            {
                                var renderable = MarkdownHtmlRenderer.BuildRenderable(responseText, ProjectRoot.ProjectRoot);
                                AnsiConsole.Write(renderable);
                            });

                            // Show a spinner if rendering takes more than 1 second. The remaining
                            // budget comes from config — big tool-grounded responses (MCP,
                            // many tables) can legitimately take 30+ seconds to render.
                            if (!renderTask.Wait(TimeSpan.FromSeconds(1)))
                            {
                                Spinner.Start("Rendering...");
                                var remainingSeconds = Math.Max(1, Config.MarkdownRenderTimeoutSeconds - 1);
                                if (!renderTask.Wait(TimeSpan.FromSeconds(remainingSeconds)))
                                {
                                    Spinner.Stop();
                                    // Rendering exceeded the configured budget — fall back to raw text
                                    Console.WriteLine();
                                    Console.Write(responseText);
                                    Console.WriteLine();
                                    AnsiConsole.MarkupLine($"[dim](markdown rendering timed out after {Config.MarkdownRenderTimeoutSeconds}s — showing raw text. Raise with /config or mandocode --config set renderTimeout 120)[/]");
                                }
                                else if (renderTask.IsFaulted)
                                {
                                    Spinner.Stop();
                                    throw renderTask.Exception!.InnerException ?? renderTask.Exception;
                                }
                                else
                                {
                                    Spinner.Stop();
                                }
                            }
                            else if (renderTask.IsFaulted)
                            {
                                throw renderTask.Exception!.InnerException ?? renderTask.Exception;
                            }
                        }
                        catch (Exception renderEx)
                        {
                            System.Diagnostics.Debug.WriteLine($"[MandoCode] Render failed: {renderEx.Message}");
                            // Fallback to raw text if markdown rendering fails
                            Console.Write(responseText);
                        }

                        // Add to chat history (ANSI capture deferred to Phase 2)
                        _messages.Add(new ChatMsg
                        {
                            Role = "assistant",
                            Text = responseText
                        });

                        // 401 auto-recovery: if the response is a 401 sign-in error,
                        // immediately launch the cloud sign-in walkthrough so the user
                        // can hit "Sign me in now" without typing /setup. Saves a step
                        // every single time this hits.
                        if (Looks401(responseText))
                        {
                            await TryAutoSigninAfter401Async();
                        }

                        // Show per-response token summary (right-aligned, tight to response)
                        if (Config.EnableTokenTracking)
                        {
                            var lastOp = TokenTracker.LastOperation;
                            if (lastOp != null && !lastOp.IsEstimate)
                            {
                                var inLabel = $"~{TokenTrackingService.FormatTokenCount(lastOp.PromptTokens)} in";
                                var outLabel = $"{TokenTrackingService.FormatTokenCount(lastOp.CompletionTokens)} out";
                                var tpsLabel = lastOp.TokensPerSecond.HasValue
                                    ? $": {lastOp.TokensPerSecond.Value:0.#} tok/s"
                                    : "";
                                var totalLabel = TokenTrackingService.FormatTokenCount(TokenTracker.TotalSessionTokens);
                                var tokenSummary = $"[{inLabel}, {outLabel}{tpsLabel}]";
                                var pad = Math.Max(0, Console.WindowWidth - tokenSummary.Length - 1);
                                Console.WriteLine();
                                Console.WriteLine($"\u001b[2m{new string(' ', pad)}{tokenSummary}\u001b[0m");
                            }
                        }

                    }

                    // Update title bar with latest model/project/token info
                    ThemeService.UpdateStatusTitle();
                }
            }
            finally
            {
                Spinner.Stop();
                await enumerator.DisposeAsync();
            }

            AnsiConsole.WriteLine();
        }
        catch (OperationCanceledException)
        {
            Spinner.Stop();
            AnsiConsole.WriteLine();
            AnsiConsole.MarkupLine("[yellow]Request cancelled.[/]");
            AnsiConsole.WriteLine();
        }
        catch (Exception ex)
        {
            Spinner.Stop();
            AnsiConsole.WriteLine($"Error: {ex.Message}");
            AnsiConsole.WriteLine();
        }
        finally
        {
            StopCancelKeyListener();
            var oldCts = Interlocked.Exchange(ref _requestCts, null);
            oldCts?.Dispose();
        }
    }

    /// <summary>
    /// Called by <see cref="PlanHandoff"/> when the model invokes propose_plan.
    /// Shows the approval UI, runs execution if approved, and returns a summary
    /// string that the model will see as the tool result.
    /// </summary>
    private async Task<string> HandleProposedPlanAsync(TaskPlan plan, CancellationToken ct)
    {
        // Stop the outer "Thinking..." spinner so it doesn't fight the approval prompt.
        Spinner.Stop();

        AnsiConsole.WriteLine();
        DisplayPlan(plan);

        string choice;
        using (KeyCoordinator.Suppress())
        {
            choice = AnsiConsole.Prompt(
                new SelectionPrompt<string>()
                    .Title("The assistant proposes this plan. What would you like to do?")
                    .AddChoices(new[] { "Execute plan", "Reject (answer without a plan)", "Cancel request" })
            );
        }

        if (choice == "Cancel request")
        {
            AnsiConsole.MarkupLine("[dim]Plan cancelled.[/]");
            AnsiConsole.WriteLine();
            return "User cancelled the request. Stop here and do not take further action.";
        }

        if (choice == "Reject (answer without a plan)")
        {
            AnsiConsole.MarkupLine("[dim]Plan rejected — continuing without stepwise execution.[/]");
            AnsiConsole.WriteLine();
            return "User rejected the proposed plan. Respond to the original request directly without calling propose_plan again.";
        }

        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[green]Executing plan...[/]");
        AnsiConsole.WriteLine();

        try
        {
            await foreach (var progressEvent in TaskPlanner.ExecutePlanAsync(plan, ct))
            {
                await HandleProgressEventAsync(progressEvent, plan);
            }
        }
        catch (OperationCanceledException)
        {
            Spinner.Stop();
            TaskPlanner.CancelPlan(plan);
        }

        AnsiConsole.WriteLine();
        if (plan.Status == TaskPlanStatus.Completed)
        {
            AnsiConsole.MarkupLine("[green]Plan completed successfully![/]");
        }
        else if (plan.Status == TaskPlanStatus.Cancelled)
        {
            AnsiConsole.MarkupLine("[yellow]Plan was cancelled.[/]");
        }
        else
        {
            AnsiConsole.MarkupLine("[red]Plan completed with errors.[/]");
        }

        if (!string.IsNullOrEmpty(plan.ExecutionSummary))
        {
            AnsiConsole.MarkupLine($"[dim]{Spectre.Console.Markup.Escape(plan.ExecutionSummary)}[/]");
        }
        AnsiConsole.WriteLine();

        return plan.ExecutionSummary
               ?? $"Plan finished with status {plan.Status}.";
    }

    private void DisplayPlan(TaskPlan plan)
    {
        var table = new Spectre.Console.Table()
            .Border(TableBorder.Rounded)
            .AddColumn(new TableColumn("Step").Centered())
            .AddColumn(new TableColumn("Description"));

        foreach (var step in plan.Steps)
        {
            table.AddRow(
                $"[cyan]{step.StepNumber}[/]",
                Spectre.Console.Markup.Escape(step.Description)
            );
        }

        AnsiConsole.MarkupLine("[cyan]Created plan:[/]");
        AnsiConsole.WriteLine();
        AnsiConsole.Write(table);
        AnsiConsole.WriteLine();
    }

    private async Task HandleProgressEventAsync(TaskProgressEvent progressEvent, TaskPlan plan)
    {
        switch (progressEvent.ProgressType)
        {
            case TaskProgressType.StepStarted:
                Spinner.Stop();
                _recentReadCount = 0;
                _recentReadFiles.Clear();
                _lastOperationType = null;
                SpinnerService.SetTaskbarProgress((progressEvent.CurrentStep - 1) * 100 / progressEvent.TotalSteps);
                AnsiConsole.MarkupLine($"[cyan]Step {progressEvent.CurrentStep}/{progressEvent.TotalSteps}:[/] {Spectre.Console.Markup.Escape(progressEvent.StepDescription)}");
                AnsiConsole.WriteLine();
                Spinner.Start("Working...");
                break;

            case TaskProgressType.StepCompleted:
                Spinner.Stop();
                SpinnerService.SetTaskbarProgress(progressEvent.CurrentStep * 100 / progressEvent.TotalSteps);
                if (!string.IsNullOrEmpty(progressEvent.Message))
                {
                    // Truncate long results for display
                    var displayMessage = progressEvent.Message.Length > 500
                        ? progressEvent.Message[..500] + "..."
                        : progressEvent.Message;
                    AnsiConsole.Markup(Spectre.Console.Markup.Escape(displayMessage));
                    AnsiConsole.WriteLine();
                }
                AnsiConsole.MarkupLine($"[green]Step {progressEvent.CurrentStep} completed.[/]");
                AnsiConsole.WriteLine();
                break;

            case TaskProgressType.StepFailed:
                Spinner.Stop();
                SpinnerService.SetTaskbarError(progressEvent.CurrentStep * 100 / progressEvent.TotalSteps);
                AnsiConsole.MarkupLine($"[red]Step {progressEvent.CurrentStep} failed:[/] {Spectre.Console.Markup.Escape(progressEvent.Message ?? "Unknown error")}");

                // Ask user what to do
                string failChoice;
                using (KeyCoordinator.Suppress())
                {
                    failChoice = AnsiConsole.Prompt(
                        new SelectionPrompt<string>()
                            .Title("How would you like to proceed?")
                            .AddChoices(new[] { "Skip this step and continue", "Cancel the plan" })
                    );
                }

                if (failChoice == "Cancel the plan")
                {
                    TaskPlanner.CancelPlan(plan);
                }
                else
                {
                    var failedStep = plan.Steps.FirstOrDefault(s => s.StepNumber == progressEvent.CurrentStep);
                    if (failedStep != null)
                    {
                        TaskPlanner.SkipStep(plan, failedStep);
                        SpinnerService.SetTaskbarWarning(progressEvent.CurrentStep * 100 / progressEvent.TotalSteps);
                    }
                }
                break;

            case TaskProgressType.PlanCompleted:
                Spinner.Stop();
                SpinnerService.ClearTaskbarProgress();
                break;

            case TaskProgressType.PlanCancelled:
                Spinner.Stop();
                SpinnerService.ClearTaskbarProgress();
                break;
        }
    }

