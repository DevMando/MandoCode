@using MandoCode.Models
@using MandoCode.Services
@using System.Collections.Generic
@using System.Text.RegularExpressions
@using Spectre.Console
@inject AIService AI
@inject MandoCodeConfig Config
@inject TaskPlannerService TaskPlanner
@inject FileAutocompleteProvider FileProvider
@inject TokenTrackingService TokenTracker
@inject MusicPlayerService MusicPlayer
@inject ProjectRootAccessor ProjectRoot
@inject SpinnerService Spinner
@inject OperationDisplayRenderer OperationRenderer
@inject DiffApprovalHandler DiffApproval
@inject ShellCommandHandler Shell
@inject TerminalThemeService ThemeService
@inject InputStateMachine StateMachine
@implements IDisposable

<Banner />

<Rows>
    <Markup Content="@($"Project Root: {ProjectRoot.ProjectRoot}")" Background="Color.Black" />
    <Markup Content="@($"Ollama Endpoint: {Config.OllamaEndpoint}")" />
    <Markup Content="@($"Model: {Config.GetEffectiveModelName()}")" />

    @if (!_connectionChecked)
    {
        <Markup Content="🔄 Connecting to Ollama..." />
    }
    else if (!_isConnected)
    {
        <Panel Border="@BoxBorder.Rounded" BorderColor="Color.Yellow">
            <Rows>
                <Markup Content="@($"[yellow]Unable to reach Ollama at[/] [white]{Spectre.Console.Markup.Escape(Config.OllamaEndpoint)}[/]")" />
                @if (!string.IsNullOrEmpty(_connectionStatusMessage))
                {
                    <Markup Content="@_connectionStatusMessage" />
                }
                <Markup Content="[bold]Next steps:[/]" />
                <Markup Content="  1. Install Ollama from https://ollama.com" />
                <Markup Content="  2. In another terminal run: [cyan]ollama serve[/]" />
                <Markup Content="  3. Pull a model (e.g. [cyan]ollama pull qwen3:8b[/])" />
                <Markup Content="  4. Return here and type [cyan]/retry[/] to reconnect" />
                <Markup Content="[dim]You can still run /config or /learn while offline.[/]" />
            </Rows>
        </Panel>
        LearnContent.Display();
    }
    else if (!string.IsNullOrEmpty(_modelWarning))
    {
        <Panel Border="@BoxBorder.Ascii" BorderColor="Color.Yellow">
            <Rows>
                <Markup Content="@_modelWarning" />
            </Rows>
        </Panel>
    }
    else
    {
        <Markup Content="✅ MandoCode is ready!" />
        <HelpDisplay />
        <Markup Content="@("Tip: reference files inline, e.g. What does @Program.cs do?")" />
    }
</Rows>

@* VDOM input — always rendered once interactive loop starts, disabled during processing *@
@if (_showPrompt)
{
    <PromptInput OnSubmit="HandleVdomSubmit"
                 OnAutocompleteRequested="HandleAutocompleteRequested"
                 InitialValue="@_promptInitialValue"
                 Disabled="@_isProcessing" />
}

@code {
    protected bool _isConnected { get; set; } = false;
    private bool _connectionChecked = false;
    private bool _hasRendered = false;
    private string? _modelWarning = null;
    private bool _modelError = false;
    private string? _connectionStatusMessage = null;

    // Last AI response for /copy command
    private string? _lastAiResponse;

    // True while an AI request or command is processing — disables the input

    // Chat history for VDOM rendering
    private List<ChatMsg> _messages = new();
    private List<string> _pendingOperations = new();

    // Cancellation for active AI requests — triggered by Ctrl+C or Escape
    private CancellationTokenSource? _requestCts;
    private CancellationTokenSource? _keyListenerCts;

    // Tracks recent function operations for contextual spinner messages
    private int _recentReadCount;
    private readonly List<string> _recentReadFiles = new();
    private string? _lastOperationType;

    // VDOM input bridge — TaskCompletionSource lets the interactive loop
    // await user input from the PromptInput Blazor component without blocking
    private TaskCompletionSource<string>? _inputTcs;
    private bool _showPrompt = false;
    private bool _isProcessing = false;
    private bool _autocompleteActive = false;
    private string _promptInitialValue = "";


    // Music visualizer — animated equalizer while music plays
    private CancellationTokenSource? _musicVisCts;
    private Task? _musicVisTask;
    private readonly object _musicVisLock = new();



    private void StartMusicVisualizer()
    {
        // Early-exit if a visualizer CTS is already active
        lock (_musicVisLock)
        {
            if (_musicVisCts != null)
                return;
        }

        StopMusicVisualizer();

        if (!MusicPlayer.IsPlaying && !MusicPlayer.IsPaused)
            return;

        ThemeService.IsMusicTitleActive = true;

        var cts = new CancellationTokenSource();
        var token = cts.Token;

        var task = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    var isPlaying = MusicPlayer.IsPlaying;
                    var trackName = MusicPlayer.CurrentTrack?.Name ?? "Unknown";

                    if (!MusicPlayer.IsPlaying && !MusicPlayer.IsPaused)
                        break;

                    // Animated equalizer in the terminal title bar — always visible,
                    // never overlaps scrollback content
                    var eq = isPlaying ? MusicAsciiArt.GetEqualizerFrame() : MusicAsciiArt.GetPausedEqualizerFrame();
                    var note = MusicAsciiArt.GetRandomNote();
                    var stateIcon = isPlaying ? "\u25b6" : "\u23f8";
                    var title = $"{note} {trackName}  {eq}  {stateIcon} MandoCode";
                    Console.Write($"\u001b]0;{title}\u0007");

                    await Task.Delay(isPlaying ? 150 : 500, token);
                }
            }
            catch (OperationCanceledException) { }
            finally
            {
                // Hand title bar back to status display
                try
                {
                    ThemeService.IsMusicTitleActive = false;
                    ThemeService.UpdateStatusTitle();
                }
                catch (Exception ex) { System.Diagnostics.Debug.WriteLine($"Failed to reset music title: {ex.Message}"); }
            }
        });

        lock (_musicVisLock)
        {
            _musicVisCts = cts;
            _musicVisTask = task;
        }
    }

    private void StopMusicVisualizer()
    {
        CancellationTokenSource? cts;
        Task? task;

        lock (_musicVisLock)
        {
            cts = _musicVisCts;
            task = _musicVisTask;
            _musicVisCts = null;
            _musicVisTask = null;
        }

        if (cts != null)
        {
            cts.Cancel();
            if (task != null)
            {
                try { task.Wait(1000); } catch (AggregateException) { }
            }
            cts.Dispose();
        }
    }

    protected override void OnInitialized()
    {
        // Get project root from command line args if available
        var args = Environment.GetCommandLineArgs().Skip(1).ToArray();
        if (args.Length > 0 && !args[0].StartsWith("config"))
        {
            ProjectRoot.ProjectRoot = args[0];
        }

        // Subscribe to function invocation events for UI feedback
        AI.OnFunctionInvoked += OnFunctionInvoked;
        AI.OnFunctionCompleted += OnFunctionCompleted;

        // Wire up diff approval callbacks if enabled
        if (Config.EnableDiffApprovals)
        {
            AI.OnWriteApprovalRequested = DiffApproval.HandleDiffApproval;
            AI.OnDeleteApprovalRequested = DiffApproval.HandleDeleteApproval;
            AI.OnCommandApprovalRequested = DiffApproval.HandleCommandApproval;
        }

        // Detect terminal theme and apply curated palette
        if (Config.EnableThemeCustomization)
        {
            ThemeService.DetectTheme();
            ThemeService.ApplyPalette();
        }

        // Ctrl+C cancels the active AI request instead of killing the process
        Console.CancelKeyPress += (_, e) =>
        {
            var cts = _requestCts;
            if (cts != null && !cts.IsCancellationRequested)
            {
                e.Cancel = true;   // suppress default process termination
                cts.Cancel();
            }
            else
            {
                // No active request — clean up palette before process exits
                ThemeService.ResetPalette();
            }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_connectionChecked)
        {
            await InitializeConnectionAsync();
        }

        if (_connectionChecked && !_hasRendered)
        {
            _hasRendered = true;

            // Initialize imperative input with the shared state machine
            CommandAutocomplete.Initialize(StateMachine);

            // Small delay to ensure UI is fully rendered before accepting input
            await Task.Delay(100);
            _ = Task.Run(async () => await RunInteractiveLoopAsync());
        }
    }

    private async Task InitializeConnectionAsync()
    {
        // Check Ollama connection asynchronously (moved from OnInitialized to avoid blocking)
        _isConnected = await CheckOllamaConnectionAsync();
        _connectionChecked = true;

        if (_isConnected)
        {
            _connectionStatusMessage = null;
            await ValidateCurrentModelAsync();
        }
        else
        {
            _connectionStatusMessage = "[dim]Start 'ollama serve', pull a model, then type /retry to check again.[/]";
        }

        // Re-render so the VDOM updates from /learn content to the ready state
        await InvokeAsync(StateHasChanged);
    }

    private async Task ValidateCurrentModelAsync()
    {
        // Validate that model supports function calling
        var (isValid, errorMessage) = await AI.ValidateModelAsync();
        if (!isValid && errorMessage != null)
        {
            // Show warning but allow user to continue
            AnsiConsole.WriteLine();
            AnsiConsole.MarkupLine("[yellow]Warning:[/]");
            AnsiConsole.WriteLine(errorMessage);
            AnsiConsole.WriteLine();

            if (errorMessage.Contains("Continue anyway?"))
            {
                var continueAnyway = AnsiConsole.Confirm("Continue with this model?", false);
                if (!continueAnyway)
                {
                    AnsiConsole.WriteLine("Please configure a supported model:");
                    AnsiConsole.WriteLine("  mandocode --config set model qwen2.5-coder:14b");
                    AnsiConsole.WriteLine("  ollama pull qwen2.5-coder:14b");
                    ThemeService.ResetPalette();
                    ThemeService.Dispose();
                    Environment.Exit(1);
                    return;
                }
            }
            else
            {
                // Hard error (model not found) — enter limited mode
                _modelError = true;
                _modelWarning = errorMessage;
                AnsiConsole.WriteLine();
                AnsiConsole.MarkupLine("[yellow]You can fix this by:[/]");
                AnsiConsole.MarkupLine("[dim]  1. Pull the model:[/] ollama pull <model-name>");
                AnsiConsole.MarkupLine("[dim]  2. Run[/] /config [dim]to select a different model[/]");
                AnsiConsole.MarkupLine("[dim]  3. Make sure Ollama is running:[/] ollama serve");
                AnsiConsole.WriteLine();
            }
        }
        else
        {
            _modelError = false;
            _modelWarning = null;
        }
    }

    private void OnFunctionInvoked(FunctionCall call)
    {
        // Pause the spinner so the message renders on a clean line
        Spinner.Stop();

        // Track operation type for contextual spinner messages
        _lastOperationType = call.FunctionName.Replace("FileSystem_", "").ToLowerInvariant();

        // Suppress display for known FileSystem operations — they will be shown
        // as rich operation displays when OnFunctionCompleted fires
        if (!IsFileSystemOperation(call.FunctionName))
        {
            AnsiConsole.MarkupLine($"[dim][[Function]][/] [cyan]{Spectre.Console.Markup.Escape(call.Description)}[/]");
        }

        // Show what the model is doing above the spinner in grey
        Spinner.Start(call.Description);
    }

    private void OnFunctionCompleted(MandoCode.Models.FunctionExecutionResult result)
    {
        // Pause the spinner so the message renders on a clean line
        Spinner.Stop();

        if (result.OperationDisplay != null)
        {
            // Render directly to stdout (capture deferred to Phase 2)
            OperationRenderer.Render(result.OperationDisplay);

            // Track consecutive reads for contextual spinner messages
            if (result.OperationDisplay.OperationType == "Read")
            {
                _recentReadCount++;
                var fileName = Path.GetFileName(result.OperationDisplay.FilePath);
                if (!string.IsNullOrEmpty(fileName))
                    _recentReadFiles.Add(fileName);
            }
            else
            {
                // Non-read operation resets the read tracker
                _recentReadCount = 0;
                _recentReadFiles.Clear();
            }
        }
        else if (result.Success)
        {
            AnsiConsole.MarkupLine($"[dim][[Done]][/] [green]✓[/]");
        }
        else
        {
            AnsiConsole.MarkupLine($"[dim][[Error]][/] [red]{Spectre.Console.Markup.Escape(result.Result)}[/]");
        }

        // Refresh file cache after any operation that modifies the file system
        var fnLower = result.FunctionName.ToLowerInvariant();
        if (fnLower.Contains("write") || fnLower.Contains("delete") || fnLower.Contains("create") || fnLower.Contains("folder"))
        {
            FileProvider.RefreshCache();
        }

        // Show contextual spinner message based on what just happened
        var activity = GetContextualActivity(result);
        Spinner.Start(activity);
    }

    /// <summary>
    /// Generates a contextual activity message for the spinner based on recent operations.
    /// </summary>
    private string? GetContextualActivity(FunctionExecutionResult result)
    {
        var opType = result.OperationDisplay?.OperationType ?? _lastOperationType ?? "";

        return opType switch
        {
            "Read" when _recentReadCount >= 2 => $"Analyzing {_recentReadCount} files...",
            "Read" => "Analyzing file...",
            "Write" or "Update" => "Applying changes...",
            "Search" => "Reviewing search results...",
            "Glob" => "Scanning project structure...",
            "WebSearch" => "Processing search results...",
            "WebFetch" => "Reading web content...",
            "Delete" => "Continuing...",
            "Command" => "Processing command output...",
            _ => null
        };
    }

    /// <summary>
    /// Checks if a function name belongs to the FileSystem plugin.
    /// </summary>
    private bool IsFileSystemOperation(string functionName)
    {
        return functionName.StartsWith("FileSystem_", StringComparison.Ordinal);
    }

    private async Task<bool> CheckOllamaConnectionAsync()
    {
        try
        {
            using var client = new HttpClient { Timeout = TimeSpan.FromSeconds(5) };
            var response = await client.GetAsync($"{Config.OllamaEndpoint}/api/tags");
            return response.IsSuccessStatusCode;
        }
        catch
        {
            return false;
        }
    }

    private async Task RunInteractiveLoopAsync()
    {
        while (true)
        {
            // Show session token count right-aligned above prompt
            if (Config.EnableTokenTracking && TokenTracker.TotalSessionTokens > 0)
            {
                var tokenDisplay = $"Total [{TokenTrackingService.FormatTokenCount(TokenTracker.TotalSessionTokens)} tokens]";
                var padding = Math.Max(0, Console.WindowWidth - tokenDisplay.Length - 1);
                Console.WriteLine($"\u001b[2m{new string(' ', padding)}{tokenDisplay}\u001b[0m");
            }

            // Ensure music visualizer is running if music is active
            // (it writes to a fixed upper-right screen position via ANSI escapes, no prompt conflict)
            StartMusicVisualizer();

            // Await user input via VDOM PromptInput component.
            var input = await WaitForVdomInputAsync();

            if (string.IsNullOrWhiteSpace(input))
                continue;

            // Echo the submitted input in gold so it persists in terminal scrollback.
            // The 100ms delay in WaitForVdomInputAsync ensures the VDOM repaint
            // (which removes PromptInput) has completed before this write.
            Console.Write($"\u001b[38;2;255;200;80m> {input}\u001b[0m");
            Console.WriteLine();

            // Shell escape: !<cmd> runs a shell command inline
            if (input.TrimStart().StartsWith('!'))
            {
                await Shell.HandleShellCommandAsync(input.TrimStart()[1..].Trim());
                continue;
            }

            // Check if this is a command (starts with /)
            if (InputStateMachine.IsCommand(input))
            {
                var command = InputStateMachine.GetCommandName(input);

                // Handle special commands
                if (command == "exit")
                {
                    StopMusicVisualizer();
                    MusicPlayer.Dispose();
                    ThemeService.Dispose();
                    AnsiConsole.WriteLine("Goodbye!");
                    Environment.Exit(0);
                    return;
                }

                if (command == "clear")
                {
                    await AI.ClearHistoryAsync();
                    StateMachine.ClearHistory();
                    Console.Clear();
                    AnsiConsole.WriteLine("Conversation cleared.");
                    continue;
                }

                if (command == "help")
                {
                    Console.WriteLine();
                    // Display help (we'll use direct Spectre.Console since HelpDisplay is a component)
                    var table = new Spectre.Console.Table()
                    {
                        Border = TableBorder.Rounded
                    };
                    table.AddColumn("Command");
                    table.AddColumn("Description");
                    table.AddRow("/help", "Show this help message");
                    table.AddRow("/config", "Open configuration menu");
                    table.AddRow("/retry", "Retry Ollama connection");
                    table.AddRow("/learn", "Learn about LLMs and local AI models");
                    table.AddRow("/music", "Play lofi/synthwave coding music");
                    table.AddRow("/music-stop", "Stop music playback");
                    table.AddRow("/music-pause", "Pause/resume music");
                    table.AddRow("/music-next", "Skip to next track");
                    table.AddRow("/music-vol", "Set volume (0-100)");
                    table.AddRow("/music-lofi", "Switch to lofi genre");
                    table.AddRow("/music-synthwave", "Switch to synthwave genre");
                    table.AddRow("/music-list", "Show available tracks");
                    table.AddRow("/command", "Run a shell command (also: !<cmd>)");
                    table.AddRow("/copy", "Copy last AI response to clipboard");
                    table.AddRow("/copy-code", "Copy code blocks from last response");
                    table.AddRow("/clear", "Clear conversation history");
                    table.AddRow("/exit", "Exit MandoCode");
                    AnsiConsole.Write(table);
                    AnsiConsole.WriteLine();
                    AnsiConsole.WriteLine("Examples:");
                    AnsiConsole.WriteLine("  • What files are in this project?");
                    AnsiConsole.WriteLine("  • Show me the contents of Program.cs");
                    AnsiConsole.WriteLine("  • Refactor the Main method to use async/await");
                    AnsiConsole.WriteLine("  • What's the current git status?");
                    AnsiConsole.WriteLine();
                    continue;
                }

                if (command == "config")
                {
                    await HandleConfigCommandAsync();
                    continue;
                }

                if (command == "learn")
                {
                    await HandleLearnCommandAsync();
                    continue;
                }

                if (command == "retry")
                {
                    await HandleRetryCommandAsync();
                    continue;
                }

                if (command == "copy")
                {
                    HandleCopyCommand();
                    continue;
                }

                if (command == "copy-code")
                {
                    HandleCopyCodeCommand();
                    continue;
                }

                if (command == "rabbit")
                {
                    HandleRabbitCommand();
                    continue;
                }

                // Music commands
                if (command == "music")           { HandleMusicCommand("play"); continue; }
                if (command == "music-stop")      { HandleMusicCommand("stop"); continue; }
                if (command == "music-pause")     { HandleMusicCommand("pause"); continue; }
                if (command == "music-next")      { HandleMusicCommand("next"); continue; }
                if (command == "music-playlist")      { HandleMusicPlaySelection(); continue; }
                if (command == "music-list")      { HandleMusicCommand("list"); continue; }
                if (command.StartsWith("music-vol"))
                {
                    HandleMusicCommand(command);
                    continue;
                }

                if (command == "command" || command.StartsWith("command "))
                {
                    var shellCmd = command.Length > 7 ? command[8..].Trim() : "";
                    await Shell.HandleShellCommandAsync(shellCmd);
                    continue;
                }

                // Unknown command
                AnsiConsole.MarkupLine($"[red]Unknown command: {Spectre.Console.Markup.Escape(input)}[/]");
                AnsiConsole.MarkupLine("[dim]Type /help for available commands[/]");
                AnsiConsole.WriteLine();
                continue;
            }

            if (!_isConnected)
            {
                ShowOfflineGuidance();
                continue;
            }

            // Block AI requests when model is not available
            if (_modelError)
            {
                AnsiConsole.MarkupLine("[yellow]No model loaded.[/] Run [cyan]/config[/] to select a model, or pull one with [cyan]ollama pull <model-name>[/].");
                AnsiConsole.WriteLine();
                continue;
            }

            // Matrix easter egg: play a cinematic moment for trigger phrases
            if (ContainsMatrixTrigger(input))
            {
                PlayMatrixMoment(input);
            }

            // Check if this request needs task planning BEFORE injecting file content,
            // so that attached file size doesn't inflate the complexity heuristics
            var needsPlanning = TaskPlanner.RequiresPlanning(input);

            // Process @file references and inject file content
            var processedInput = ProcessFileReferences(input);

            if (needsPlanning)
            {
                // Add user message to chat history
                _messages.Add(new ChatMsg { Role = "user", Text = input });
                await HandlePlannedExecutionAsync(processedInput);
                continue;
            }

            // Add user message to chat history
            _messages.Add(new ChatMsg { Role = "user", Text = input });

            // Process AI request with streaming (non-command input)
            await ProcessDirectRequestAsync(processedInput);
        }
    }

    /// <summary>
    /// Called by PromptInput when the user submits text via the VDOM TextInput.
    /// Completes the TaskCompletionSource so the interactive loop can continue.
    /// </summary>
    private void HandleVdomSubmit(string input)
    {
        _inputTcs?.TrySetResult(input);
    }

    /// <summary>
    /// Called by PromptInput when @ or / triggers autocomplete.
    /// Hides VDOM, runs imperative autocomplete (Console.ReadKey loop),
    /// then completes with the full input line.
    /// </summary>
    private async Task HandleAutocompleteRequested(string currentInput)
    {
        if (_autocompleteActive) return;
        _autocompleteActive = true;

        try
        {
            // 1. Hide PromptInput so Console.ReadKey doesn't conflict with VDOM
            _showPrompt = false;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(100); // Wait for VDOM repaint

            // 2. Run imperative autocomplete on a background thread
            //    Console.ReadKey blocks, so we use Task.Run.
            //    ContinueAutocomplete() picks up from the current state machine state
            //    (already has "@" or "/..." from PromptInput's HandleInput) — no reset.
            //    Returns null if user erased the trigger (@ or /) — go back to VDOM.
            var result = await Task.Run(() => CommandAutocomplete.ContinueAutocomplete());

            // Drain any buffered keystrokes typed while the prompt was hidden
            var resumeText = result ?? StateMachine.State.InputText;
            var buffered = DrainConsoleKeyBuffer();
            if (!string.IsNullOrEmpty(buffered))
            {
                resumeText += buffered;
                StateMachine.UpdateText(resumeText);
            }

            _promptInitialValue = resumeText;
        }
        finally
        {
            _autocompleteActive = false;
            _showPrompt = true;
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Shows the VDOM PromptInput component and awaits user submission.
    /// Returns the submitted text without blocking the Blazor render thread.
    /// The prompt stays visible but disabled during processing — this avoids
    /// border artifacts that occur when the component is removed from the VDOM tree.
    /// </summary>
    private async Task<string> WaitForVdomInputAsync()
    {
        _inputTcs = new TaskCompletionSource<string>();
        _promptInitialValue = "";
        _showPrompt = true;
        _isProcessing = false;
        await InvokeAsync(StateHasChanged);

        var input = await _inputTcs.Task;

        // Hide the prompt during processing
        _showPrompt = false;
        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        // Wait for the VDOM repaint to finish removing the PromptInput
        // before any imperative Console.Write calls
        await Task.Delay(100);

        return input;
    }

    private string ProcessFileReferences(string input)
    {
        var pattern = @"@([\w.\-/\\]+[\w.])";
        var matches = Regex.Matches(input, pattern);

        if (matches.Count == 0)
            return input;

        var contextBlocks = new System.Text.StringBuilder();
        var referencedFiles = new HashSet<string>();

        foreach (Match match in matches)
        {
            var filePath = match.Groups[1].Value;

            // Skip duplicates
            if (!referencedFiles.Add(filePath))
                continue;

            var content = FileProvider.ReadFileContent(filePath);
            if (content != null)
            {
                // Truncate files over 10,000 chars
                if (content.Length > 10_000)
                    content = content.Substring(0, 10_000) + "\n... [truncated]";

                contextBlocks.AppendLine($"File: {filePath}");
                contextBlocks.AppendLine("```");
                contextBlocks.AppendLine(content);
                contextBlocks.AppendLine("```");
                contextBlocks.AppendLine();

                // Track estimated tokens for @file references
                if (Config.EnableTokenTracking)
                {
                    TokenTracker.RecordEstimatedUsage(content.Length, $"@{filePath}");
                }

                // Show consistent operation display for @file reads
                var lineCount = content.Split('\n').Length;
                var readDisplay = new OperationDisplayEvent
                {
                    OperationType = "Read",
                    FilePath = filePath,
                    LineCount = lineCount
                };
                OperationRenderer.Render(readDisplay);
            }
            else
            {
                // Check if this is a directory reference
                var dirListing = FileProvider.GetDirectoryListing(filePath);
                if (dirListing != null)
                {
                    contextBlocks.AppendLine($"Directory: {filePath}/");
                    contextBlocks.AppendLine("Contents:");
                    contextBlocks.AppendLine(dirListing);
                    contextBlocks.AppendLine();

                    AnsiConsole.MarkupLine($"[dim][[Directory]][/] [cyan]{Spectre.Console.Markup.Escape(filePath)}/[/]");
                }
                else
                {
                    AnsiConsole.MarkupLine($"[dim][[Not found]][/] [yellow]{Spectre.Console.Markup.Escape(filePath)}[/]");
                }
            }
        }

        if (contextBlocks.Length == 0)
            return input;

        var fullContext = new System.Text.StringBuilder();
        fullContext.AppendLine("--- Referenced Files ---");
        fullContext.Append(contextBlocks);
        fullContext.AppendLine("---");
        fullContext.AppendLine();
        fullContext.Append(input);

        return fullContext.ToString();
    }

    private static string DrainConsoleKeyBuffer()
    {
        if (!Console.KeyAvailable)
            return string.Empty;

        var chars = new List<char>();
        while (Console.KeyAvailable)
        {
            var key = Console.ReadKey(intercept: true);

            if (key.Key is ConsoleKey.Enter or ConsoleKey.Escape)
                continue;

            if (!char.IsControl(key.KeyChar))
                chars.Add(key.KeyChar);
        }

        return chars.Count > 0 ? new string(chars.ToArray()) : string.Empty;
    }

    private void ShowOfflineGuidance()
    {
        var endpoint = Spectre.Console.Markup.Escape(Config.OllamaEndpoint);
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine($"[yellow]MandoCode can't reach Ollama at {endpoint}.[/]");
        AnsiConsole.MarkupLine("[dim]Start 'ollama serve', pull a model, then type /retry to reconnect.[/]");
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// Starts a background task that listens for Escape key presses and cancels _requestCts.
    /// Call StopCancelKeyListener() when the AI request completes to clean up.
    /// </summary>
    private void StartCancelKeyListener()
    {
        var listenerCts = new CancellationTokenSource();
        _keyListenerCts = listenerCts;

        Task.Run(async () =>
        {
            try
            {
                while (!listenerCts.Token.IsCancellationRequested)
                {
                    if (Console.KeyAvailable)
                    {
                        var key = Console.ReadKey(intercept: true);
                        if (key.Key == ConsoleKey.Escape)
                        {
                            var cts = _requestCts;
                            if (cts != null && !cts.IsCancellationRequested)
                            {
                                cts.Cancel();
                            }
                            break;
                        }
                    }
                    await Task.Delay(50, listenerCts.Token);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    /// <summary>
    /// Stops the background Escape key listener.
    /// </summary>
    private void StopCancelKeyListener()
    {
        var cts = Interlocked.Exchange(ref _keyListenerCts, null);
        if (cts != null)
        {
            cts.Cancel();
            cts.Dispose();
        }
    }

    private async Task ProcessDirectRequestAsync(string input)
    {
        // Reset operation tracking for the new request
        _recentReadCount = 0;
        _recentReadFiles.Clear();
        _lastOperationType = null;

        AnsiConsole.WriteLine();

        _requestCts = new CancellationTokenSource();
        var token = _requestCts.Token;
        StartCancelKeyListener();

        try
        {
            var receivedFirstChunk = false;
            var enumerator = AI.ChatStreamAsync(input, token).GetAsyncEnumerator(token);

            try
            {
                // Show our controllable spinner while waiting for first chunk
                // This spinner can be stopped by HandleDiffApproval when it needs user input
                Spinner.Start("Thinking...");

                if (await enumerator.MoveNextAsync())
                {
                    receivedFirstChunk = true;
                }

                Spinner.Stop();

                if (!receivedFirstChunk)
                {
                    AnsiConsole.MarkupLine("[yellow]No response from model. The request may have exceeded the model's context window.[/]");
                    AnsiConsole.MarkupLine("[dim]Try a smaller request, or switch to a model with a larger context window via /config.[/]");
                }

                // Buffer all chunks, then render as rich markdown
                if (receivedFirstChunk)
                {
                    var responseBuffer = new System.Text.StringBuilder();
                    var lineBuffer = new System.Text.StringBuilder();
                    var showSpinnerBeforeNextChunk = false;

                    void AccumulateChunk(string chunk)
                    {
                        responseBuffer.Append(chunk);
                        foreach (char c in chunk)
                        {
                            if (c == '\n')
                            {
                                if (lineBuffer.ToString().Contains('\u2699'))
                                    showSpinnerBeforeNextChunk = true;
                                lineBuffer.Clear();
                            }
                            else if (c != '\r')
                            {
                                lineBuffer.Append(c);
                            }
                        }
                    }

                    AccumulateChunk(enumerator.Current);

                    var hasMore = true;
                    while (hasMore)
                    {
                        if (showSpinnerBeforeNextChunk)
                        {
                            showSpinnerBeforeNextChunk = false;
                            Spinner.Start();
                            hasMore = await enumerator.MoveNextAsync();
                            Spinner.Stop();
                        }
                        else
                        {
                            hasMore = await enumerator.MoveNextAsync();
                        }

                        if (hasMore)
                            AccumulateChunk(enumerator.Current);
                    }

                    // Render the complete response as rich markdown
                    var responseText = responseBuffer.ToString().Trim();
                    if (string.IsNullOrEmpty(responseText))
                    {
                        AnsiConsole.MarkupLine("[yellow]Model returned an empty response. The context may be too large for this model.[/]");
                        AnsiConsole.MarkupLine("[dim]Try a smaller request, or switch to a model with a larger context window via /config.[/]");
                    }
                    else
                    {
                        _lastAiResponse = responseText;

                        try
                        {
                            AnsiConsole.MarkupLine("[green]MandoCode:[/]");

                            // Guard against rendering hangs on malformed/huge responses.
                            // Large responses with many tables/code blocks can take 10+ seconds to render.
                            var renderTask = Task.Run(() =>
                            {
                                var renderable = MarkdownRenderer.BuildRenderable(responseText);
                                AnsiConsole.Write(renderable);
                            });

                            // Show a spinner if rendering takes more than 1 second
                            if (!renderTask.Wait(TimeSpan.FromSeconds(1)))
                            {
                                Spinner.Start("Rendering...");
                                if (!renderTask.Wait(TimeSpan.FromSeconds(29)))
                                {
                                    Spinner.Stop();
                                    // Rendering took over 30 seconds — fall back to raw text
                                    Console.WriteLine();
                                    Console.Write(responseText);
                                    Console.WriteLine();
                                    AnsiConsole.MarkupLine("[dim](markdown rendering timed out — showing raw text)[/]");
                                }
                                else if (renderTask.IsFaulted)
                                {
                                    Spinner.Stop();
                                    throw renderTask.Exception!.InnerException ?? renderTask.Exception;
                                }
                                else
                                {
                                    Spinner.Stop();
                                }
                            }
                            else if (renderTask.IsFaulted)
                            {
                                throw renderTask.Exception!.InnerException ?? renderTask.Exception;
                            }
                        }
                        catch (Exception renderEx)
                        {
                            System.Diagnostics.Debug.WriteLine($"[MandoCode] Render failed: {renderEx.Message}");
                            // Fallback to raw text if markdown rendering fails
                            Console.Write(responseText);
                        }

                        // Add to chat history (ANSI capture deferred to Phase 2)
                        _messages.Add(new ChatMsg
                        {
                            Role = "assistant",
                            Text = responseText
                        });

                        // Show per-response token summary (right-aligned, tight to response)
                        if (Config.EnableTokenTracking)
                        {
                            var lastOp = TokenTracker.LastOperation;
                            if (lastOp != null && !lastOp.IsEstimate)
                            {
                                var inLabel = $"~{TokenTrackingService.FormatTokenCount(lastOp.PromptTokens)} in";
                                var outLabel = $"{TokenTrackingService.FormatTokenCount(lastOp.CompletionTokens)} out";
                                var tpsLabel = lastOp.TokensPerSecond.HasValue
                                    ? $": {lastOp.TokensPerSecond.Value:0.#} tok/s"
                                    : "";
                                var totalLabel = TokenTrackingService.FormatTokenCount(TokenTracker.TotalSessionTokens);
                                var tokenSummary = $"[{inLabel}, {outLabel}{tpsLabel}]";
                                var pad = Math.Max(0, Console.WindowWidth - tokenSummary.Length - 1);
                                Console.WriteLine();
                                Console.WriteLine($"\u001b[2m{new string(' ', pad)}{tokenSummary}\u001b[0m");
                            }
                        }

                    }

                    // Update title bar with latest model/project/token info
                    ThemeService.UpdateStatusTitle();
                }
            }
            finally
            {
                Spinner.Stop();
                await enumerator.DisposeAsync();
            }

            AnsiConsole.WriteLine();
        }
        catch (OperationCanceledException)
        {
            Spinner.Stop();
            AnsiConsole.WriteLine();
            AnsiConsole.MarkupLine("[yellow]Request cancelled.[/]");
            AnsiConsole.WriteLine();
        }
        catch (Exception ex)
        {
            Spinner.Stop();
            AnsiConsole.WriteLine($"Error: {ex.Message}");
            AnsiConsole.WriteLine();
        }
        finally
        {
            StopCancelKeyListener();
            var oldCts = Interlocked.Exchange(ref _requestCts, null);
            oldCts?.Dispose();
        }
    }

    private async Task HandlePlannedExecutionAsync(string input)
    {
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[cyan]This looks like a complex request. Creating a plan...[/]");
        AnsiConsole.WriteLine();

        _requestCts = new CancellationTokenSource();
        var token = _requestCts.Token;
        StartCancelKeyListener();

        TaskPlan? plan = null;

        try
        {
            // Create the plan with a spinner
            await AnsiConsole.Status()
                .Spinner(LoadingMessages.GetRandomSpinner())
                .StartAsync("Analyzing request and creating plan...", async ctx =>
                {
                    plan = await TaskPlanner.CreatePlanAsync(input, token);
                });
        }
        catch (OperationCanceledException)
        {
            StopCancelKeyListener();
            var oldCts = Interlocked.Exchange(ref _requestCts, null);
            oldCts?.Dispose();
            AnsiConsole.WriteLine();
            AnsiConsole.MarkupLine("[yellow]Plan creation cancelled.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        // Stop the key listener during user interaction (plan approval prompt)
        StopCancelKeyListener();
        var planCts = Interlocked.Exchange(ref _requestCts, null);
        planCts?.Dispose();

        if (plan == null || plan.Steps.Count == 0)
        {
            AnsiConsole.MarkupLine("[yellow]Could not create a plan. Falling back to direct execution.[/]");
            await ProcessDirectRequestAsync(input);
            return;
        }

        // Display the plan
        DisplayPlan(plan);

        // Ask user to confirm
        var choice = AnsiConsole.Prompt(
            new SelectionPrompt<string>()
                .Title("What would you like to do?")
                .AddChoices(new[] { "Execute plan", "Execute directly (skip planning)", "Cancel" })
        );

        if (choice == "Cancel")
        {
            AnsiConsole.MarkupLine("[dim]Request cancelled.[/]");
            AnsiConsole.WriteLine();
            return;
        }

        if (choice == "Execute directly (skip planning)")
        {
            await ProcessDirectRequestAsync(input);
            return;
        }

        // Execute the plan with cancellation support
        _requestCts = new CancellationTokenSource();
        var execToken = _requestCts.Token;
        StartCancelKeyListener();

        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[green]Executing plan...[/]");
        AnsiConsole.WriteLine();

        try
        {
            await foreach (var progressEvent in TaskPlanner.ExecutePlanAsync(plan, execToken))
            {
                await HandleProgressEventAsync(progressEvent, plan);
            }
        }
        catch (OperationCanceledException)
        {
            Spinner.Stop();
            TaskPlanner.CancelPlan(plan);
        }
        finally
        {
            StopCancelKeyListener();
            var oldCts = Interlocked.Exchange(ref _requestCts, null);
            oldCts?.Dispose();
        }

        // Show summary
        AnsiConsole.WriteLine();
        if (plan.Status == TaskPlanStatus.Completed)
        {
            AnsiConsole.MarkupLine("[green]Plan completed successfully![/]");
        }
        else if (plan.Status == TaskPlanStatus.Cancelled)
        {
            AnsiConsole.MarkupLine("[yellow]Plan was cancelled.[/]");
        }
        else
        {
            AnsiConsole.MarkupLine("[red]Plan completed with errors.[/]");
        }

        if (!string.IsNullOrEmpty(plan.ExecutionSummary))
        {
            AnsiConsole.MarkupLine($"[dim]{Spectre.Console.Markup.Escape(plan.ExecutionSummary)}[/]");
        }
        AnsiConsole.WriteLine();
    }

    private void DisplayPlan(TaskPlan plan)
    {
        var table = new Spectre.Console.Table()
            .Border(TableBorder.Rounded)
            .AddColumn(new TableColumn("Step").Centered())
            .AddColumn(new TableColumn("Description"));

        foreach (var step in plan.Steps)
        {
            table.AddRow(
                $"[cyan]{step.StepNumber}[/]",
                Spectre.Console.Markup.Escape(step.Description)
            );
        }

        AnsiConsole.MarkupLine("[cyan]Created plan:[/]");
        AnsiConsole.WriteLine();
        AnsiConsole.Write(table);
        AnsiConsole.WriteLine();
    }

    private async Task HandleProgressEventAsync(TaskProgressEvent progressEvent, TaskPlan plan)
    {
        switch (progressEvent.ProgressType)
        {
            case TaskProgressType.StepStarted:
                Spinner.Stop();
                _recentReadCount = 0;
                _recentReadFiles.Clear();
                _lastOperationType = null;
                SpinnerService.SetTaskbarProgress((progressEvent.CurrentStep - 1) * 100 / progressEvent.TotalSteps);
                AnsiConsole.MarkupLine($"[cyan]Step {progressEvent.CurrentStep}/{progressEvent.TotalSteps}:[/] {Spectre.Console.Markup.Escape(progressEvent.StepDescription)}");
                AnsiConsole.WriteLine();
                Spinner.Start("Working...");
                break;

            case TaskProgressType.StepCompleted:
                Spinner.Stop();
                SpinnerService.SetTaskbarProgress(progressEvent.CurrentStep * 100 / progressEvent.TotalSteps);
                if (!string.IsNullOrEmpty(progressEvent.Message))
                {
                    // Truncate long results for display
                    var displayMessage = progressEvent.Message.Length > 500
                        ? progressEvent.Message[..500] + "..."
                        : progressEvent.Message;
                    AnsiConsole.Markup(Spectre.Console.Markup.Escape(displayMessage));
                    AnsiConsole.WriteLine();
                }
                AnsiConsole.MarkupLine($"[green]Step {progressEvent.CurrentStep} completed.[/]");
                AnsiConsole.WriteLine();
                break;

            case TaskProgressType.StepFailed:
                Spinner.Stop();
                SpinnerService.SetTaskbarError(progressEvent.CurrentStep * 100 / progressEvent.TotalSteps);
                AnsiConsole.MarkupLine($"[red]Step {progressEvent.CurrentStep} failed:[/] {Spectre.Console.Markup.Escape(progressEvent.Message ?? "Unknown error")}");

                // Ask user what to do
                var failChoice = AnsiConsole.Prompt(
                    new SelectionPrompt<string>()
                        .Title("How would you like to proceed?")
                        .AddChoices(new[] { "Skip this step and continue", "Cancel the plan" })
                );

                if (failChoice == "Cancel the plan")
                {
                    TaskPlanner.CancelPlan(plan);
                }
                else
                {
                    var failedStep = plan.Steps.FirstOrDefault(s => s.StepNumber == progressEvent.CurrentStep);
                    if (failedStep != null)
                    {
                        TaskPlanner.SkipStep(plan, failedStep);
                        SpinnerService.SetTaskbarWarning(progressEvent.CurrentStep * 100 / progressEvent.TotalSteps);
                    }
                }
                break;

            case TaskProgressType.PlanCompleted:
                Spinner.Stop();
                SpinnerService.ClearTaskbarProgress();
                break;

            case TaskProgressType.PlanCancelled:
                Spinner.Stop();
                SpinnerService.ClearTaskbarProgress();
                break;
        }
    }

