            .Select(g => char.ToUpper(g[0]) + g[1..])
            .ToList();
        choices.Insert(0, "Shuffle All");

        AnsiConsole.WriteLine();
        var selected = AnsiConsole.Prompt(
            new SelectionPrompt<string>()
                .Title("[green]Select a genre:[/]")
