    {
        _inputTcs?.TrySetResult(input);
    }

    /// <summary>
    /// Bound to the wizard's bare TextInput.OnSubmit. Completes whichever wizard step is awaiting.
    /// </summary>
    private void HandleWizardInputSubmit(string value)
    {
        _wizardInputTcs?.TrySetResult(value);
    }

    /// <summary>
    /// Bound to the instruction TextInput.OnSubmit. Hands the value back to whichever
    /// DiffApprovalHandler call is awaiting via the coordinator.
    /// </summary>
    private void HandleInstructionSubmit(string value)
    {
        _instructionValue = "";
        InstructionCoordinator.Submit(value ?? string.Empty);
    }

