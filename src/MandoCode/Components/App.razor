@using MandoCode.Models
@using MandoCode.Services
@using System.Collections.Generic
@using System.Text.RegularExpressions
@using Spectre.Console
@inject AIService AI
@inject MandoCodeConfig Config
@inject TaskPlannerService TaskPlanner
@inject PlanHandoff PlanHandoff
@inject FileAutocompleteProvider FileProvider
@inject TokenTrackingService TokenTracker
@inject MusicPlayerService MusicPlayer
@inject ProjectRootAccessor ProjectRoot
@inject SpinnerService Spinner
@inject OperationDisplayRenderer OperationRenderer
@inject DiffApprovalHandler DiffApproval
@inject CancelKeyCoordinator KeyCoordinator
@inject InstructionPromptCoordinator InstructionCoordinator
@inject ShellCommandHandler Shell
@inject TerminalThemeService ThemeService
@inject InputStateMachine StateMachine
@inject SkillLoader Skills
@inject McpClientManager McpManager
@inject McpApprovalGate McpGate
@implements IDisposable

<Banner />

@* Banner stays always-on (it's static, no overlap risk). The dynamic section
   below — static info + connection state + ready/help block — is hidden during
   /setup via _setupActive so the VDOM doesn't redraw on top of the wizard's
   imperative AnsiConsole output. Extracted into HomeView so the suppression is
   a single @if gate rather than wrapping a long inline block. *@
@if (!_setupActive)
{
    <HomeView ProjectRoot="@ProjectRoot.ProjectRoot"
              RuntimeVersion="@Environment.Version.ToString()"
              OllamaEndpoint="@Config.OllamaEndpoint"
              ModelName="@Config.GetEffectiveModelName()"
              ConnectionChecked="@_connectionChecked"
              IsConnected="@_isConnected"
              OnboardingStatus="@_onboardingStatus"
              ModelWarning="@_modelWarning" />
}

@* VDOM input — always rendered once interactive loop starts, disabled during processing.
   Hidden while an instruction prompt is active so the two text inputs don't fight for focus. *@
@if (_showPrompt && !InstructionCoordinator.IsActive)
{
    <PromptInput OnSubmit="HandleVdomSubmit"
                 OnAutocompleteRequested="HandleAutocompleteRequested"
                 InitialValue="@_promptInitialValue"
                 Disabled="@_isProcessing" />
}

@* Instruction input — surfaced by DiffApprovalHandler's "Provide new instructions" branch.
   Bridged via InstructionPromptCoordinator (TCS) so the imperative handler can await VDOM input. *@
@if (InstructionCoordinator.IsActive)
{
    <TextInput @bind-Value="_instructionValue"
               OnSubmit="HandleInstructionSubmit"
               Label="@InstructionCoordinator.Prompt"
               LabelColor="Color.Yellow"
               ValueColor="@(new Color(255, 200, 80))"
               PlaceholderColor="Color.Grey"
               BorderColor="Color.Yellow"
               FocusedBorderColor="Color.Yellow"
               BorderStyle="BoxBorder.Rounded"
               Expand="true"
               FocusOrder="0" />
}

@* Wizard primitives — bare RazorConsole TextInput / Select that bypass PromptInput's slash/at
   autocomplete machinery. Used by /mcp add and any future wizards that need free-form input. *@
@if (_showWizardInput)
{
    <TextInput @bind-Value="_wizardInputValue"
               OnSubmit="HandleWizardInputSubmit"
               Placeholder="@_wizardInputPlaceholder"
               ValueColor="@(new Color(255, 200, 80))"
               PlaceholderColor="Color.Grey"
               BorderColor="Color.Purple"
               FocusedBorderColor="Color.Purple"
               BorderStyle="BoxBorder.Rounded"
               Expand="true"
               FocusOrder="0" />
}
@if (_showWizardSelect)
{
    <Select TItem="string"
            Options="_wizardSelectOptions"
            Value="_wizardSelectValue"
            ValueChanged="HandleWizardSelectSubmit"
            Expand="true" />
}

@code {
    protected bool _isConnected { get; set; } = false;
    private bool _connectionChecked = false;
    private bool _hasRendered = false;
    private string? _modelWarning = null;
    private bool _modelError = false;

    // Onboarding live status — set by OnboardingFlow during preflight / serve start /
    // pull progress so the user sees a heartbeat instead of a frozen line. Empty hides
    // the indicator. Updated through SetOnboardingStatus which fires StateHasChanged.
    private string _onboardingStatus = "";

    // True while /setup-triggered onboarding is running. Hides the HomeView component
    // (static info + ready state + help table) so the wizard's imperative AnsiConsole
    // output isn't overlapped by VDOM redraws of that block. Banner stays visible the
    // whole time. Toggled with StateHasChanged in the /setup handler.
    private bool _setupActive = false;

    // Last AI response for /copy command
    private string? _lastAiResponse;

    // True while an AI request or command is processing — disables the input

    // Chat history for VDOM rendering
    private List<ChatMsg> _messages = new();
    private List<string> _pendingOperations = new();

    // Cancellation for active AI requests — triggered by Ctrl+C or Escape
    private CancellationTokenSource? _requestCts;
    private CancellationTokenSource? _keyListenerCts;

    // Tracks recent function operations for contextual spinner messages
    private int _recentReadCount;
    private readonly List<string> _recentReadFiles = new();
    private string? _lastOperationType;

    // VDOM input bridge — TaskCompletionSource lets the interactive loop
    // await user input from the PromptInput Blazor component without blocking
    private TaskCompletionSource<string>? _inputTcs;
    private bool _showPrompt = false;

    // Wizard input state — separate from the main prompt so we can spawn bare TextInput/Select
    // components for /mcp add and future wizards without inheriting PromptInput's
    // slash/at autocomplete state machine.
    private bool _showWizardInput = false;
    private string _wizardInputValue = "";
    private string _wizardInputPlaceholder = "";
    private TaskCompletionSource<string>? _wizardInputTcs;

    private bool _showWizardSelect = false;
    private string[] _wizardSelectOptions = Array.Empty<string>();
    private string _wizardSelectValue = "";
    private TaskCompletionSource<string>? _wizardSelectTcs;

    // Instruction input — bound to the VDOM TextInput surfaced when DiffApprovalHandler
    // requests instructions via InstructionPromptCoordinator.
    private string _instructionValue = "";

    private bool _isProcessing = false;
    private bool _autocompleteActive = false;
    private string _promptInitialValue = "";


    // Event handler refs, stored so Dispose can detach them cleanly
    private Action<FunctionCall>? _onFunctionInvokedHandler;
    private Action<FunctionExecutionResult>? _onFunctionCompletedHandler;
    private ConsoleCancelEventHandler? _cancelKeyHandler;

    // Music visualizer — animated equalizer while music plays
    private CancellationTokenSource? _musicVisCts;
    private Task? _musicVisTask;
    private readonly object _musicVisLock = new();



    private void StartMusicVisualizer()
    {
        // Early-exit if a visualizer CTS is already active
        lock (_musicVisLock)
        {
            if (_musicVisCts != null)
                return;
        }

        StopMusicVisualizer();

        if (!MusicPlayer.IsPlaying && !MusicPlayer.IsPaused)
            return;

        ThemeService.IsMusicTitleActive = true;

        var cts = new CancellationTokenSource();
        var token = cts.Token;

        var task = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    var isPlaying = MusicPlayer.IsPlaying;
                    var trackName = MusicPlayer.CurrentTrack?.Name ?? "Unknown";

                    if (!MusicPlayer.IsPlaying && !MusicPlayer.IsPaused)
                        break;

                    // Animated equalizer in the terminal title bar — always visible,
                    // never overlaps scrollback content
                    var eq = isPlaying ? MusicAsciiArt.GetEqualizerFrame() : MusicAsciiArt.GetPausedEqualizerFrame();
                    var note = MusicAsciiArt.GetRandomNote();
                    var stateIcon = isPlaying ? "\u25b6" : "\u23f8";
                    var title = $"{note} {trackName}  {eq}  {stateIcon} MandoCode";
                    Console.Write($"\u001b]0;{title}\u0007");

                    await Task.Delay(isPlaying ? 150 : 500, token);
                }
            }
            catch (OperationCanceledException) { }
            finally
            {
                // Hand title bar back to status display
                try
                {
                    ThemeService.IsMusicTitleActive = false;
                    ThemeService.UpdateStatusTitle();
                }
                catch (Exception ex) { System.Diagnostics.Debug.WriteLine($"Failed to reset music title: {ex.Message}"); }
            }
        });

        lock (_musicVisLock)
        {
            _musicVisCts = cts;
            _musicVisTask = task;
        }
    }

    private void StopMusicVisualizer()
    {
        CancellationTokenSource? cts;
        Task? task;

        lock (_musicVisLock)
        {
            cts = _musicVisCts;
            task = _musicVisTask;
            _musicVisCts = null;
            _musicVisTask = null;
        }

        if (cts != null)
        {
            cts.Cancel();
            if (task != null)
            {
                try { task.Wait(1000); } catch (AggregateException) { }
            }
            cts.Dispose();
        }
    }

    protected override void OnInitialized()
    {
        // Get project root from command line args if available
        var args = Environment.GetCommandLineArgs().Skip(1).ToArray();
        if (args.Length > 0 && !args[0].StartsWith("config"))
        {
            ProjectRoot.ProjectRoot = args[0];
        }

        // Subscribe to function invocation events for UI feedback.
        // Stored as fields so Dispose can detach them — AIService is a singleton, so
        // leaving handlers attached after App tears down would leak closures capturing _requestCts.
        _onFunctionInvokedHandler = OnFunctionInvoked;
        _onFunctionCompletedHandler = OnFunctionCompleted;
        AI.OnFunctionInvoked += _onFunctionInvokedHandler;
        AI.OnFunctionCompleted += _onFunctionCompletedHandler;

        // Wire the propose_plan tool handoff to the approval + execution UI
        PlanHandoff.OnPlanRequested = HandleProposedPlanAsync;

        // Re-render when DiffApprovalHandler activates the instruction TextInput.
        InstructionCoordinator.StateChanged += OnInstructionStateChanged;

        // Wire up diff approval callbacks if enabled
        if (Config.EnableDiffApprovals)
        {
            AI.OnWriteApprovalRequested = DiffApproval.HandleDiffApproval;
            AI.OnDeleteApprovalRequested = DiffApproval.HandleDeleteApproval;
            AI.OnCommandApprovalRequested = DiffApproval.HandleCommandApproval;
            McpGate.OnApprovalRequested = DiffApproval.HandleMcpApproval;
        }

        // Detect terminal theme and apply curated palette
        if (Config.EnableThemeCustomization)
        {
            ThemeService.DetectTheme();
            ThemeService.ApplyPalette();
        }

        // Ctrl+C cancels the active AI request instead of killing the process.
        // Stored as a field so Dispose can detach it — the lambda closes over _requestCts,
        // which would otherwise keep being dereferenced after teardown.
        _cancelKeyHandler = (_, e) =>
        {
            var cts = _requestCts;
            if (cts != null && !cts.IsCancellationRequested)
            {
                e.Cancel = true;   // suppress default process termination
                cts.Cancel();
            }
            else
            {
                // No active request — clean up palette before process exits
                ThemeService.ResetPalette();
            }
        };
        Console.CancelKeyPress += _cancelKeyHandler;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_connectionChecked)
        {
            await InitializeConnectionAsync();
        }

        if (_connectionChecked && !_hasRendered)
        {
            _hasRendered = true;

            // Initialize imperative input with the shared state machine
            CommandAutocomplete.Initialize(StateMachine);

            // Small delay to ensure UI is fully rendered before accepting input
            await Task.Delay(100);
            _ = Task.Run(async () => await RunInteractiveLoopAsync());
        }
    }

    private async Task InitializeConnectionAsync()
    {
        // Probe with auto-heal — silently fixes a trailing slash on the configured URL
        // (the most common config-time foot-gun) before any wizard or warning fires.
        var probe = await OllamaSetupHelper.ProbeAsync(Config.OllamaEndpoint);
        if (probe.WasHealed)
        {
            Config.OllamaEndpoint = probe.NormalizedUrl;
            Config.Save();
            AnsiConsole.MarkupLine($"[cyan]Detected trailing slash on Ollama URL — using {Spectre.Console.Markup.Escape(probe.NormalizedUrl)}[/]");
        }

        // First-run or recovering-from-broken-state: launch the guided wizard. Once a
        // user has completed (or explicitly skipped) onboarding, an unreachable Ollama
        // falls through to the static panel + /retry / /setup loop instead.
        var shouldOnboard = MandoCodeConfig.IsFirstRun() || (!probe.Ok && !Config.HasCompletedOnboarding);
        if (shouldOnboard)
        {
            // Suppress HomeView while the wizard runs — otherwise the VDOM render
            // loop repaints over imperative AnsiConsole output (most importantly
            // the `ollama signin` URL, which the user needs to be able to read
            // and copy as a fallback if the browser auto-launch fails).
            _setupActive = true;
            await InvokeAsync(StateHasChanged);
            try
            {
                await RunOnboardingFlowAsync();
                probe = await OllamaSetupHelper.ProbeAsync(Config.OllamaEndpoint);
            }
            finally
            {
                _setupActive = false;
                await InvokeAsync(StateHasChanged);
            }
        }

        _isConnected = probe.Ok;
        _connectionChecked = true;

        if (_isConnected)
        {
            await ValidateCurrentModelAsync();
            await InitializeMcpAsync();
        }

        // Re-render so the VDOM updates from /learn content to the ready state
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Runs the OnboardingFlow. Uses Spectre's imperative prompts for selects/confirms
    /// (the VDOM Select had a `>` cursor redraw glitch on the second loop iteration),
    /// but routes URL text entry through the VDOM TextInput because Spectre's
    /// TextPrompt was dropping keystrokes alongside the live render loop.
    /// </summary>
    private async Task RunOnboardingFlowAsync(bool forceInteractive = false)
    {
        var flow = new OnboardingFlow(
            setStatus: SetOnboardingStatus,
            promptTextVdom: (title, placeholder, validate, initialValue) => WizardPromptTextAsync(title, placeholder, validate, initialValue));

        try
        {
            var result = await flow.RunAsync(Config, forceInteractive);
            if (result.Connected && !string.IsNullOrEmpty(result.FinalModel))
            {
                await AI.ReinitializeAsync(Config);
            }
        }
        finally
        {
            SetOnboardingStatus("");
        }
    }

    private void SetOnboardingStatus(string status)
    {
        _onboardingStatus = status ?? "";
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Quick string sniff for "this response is a 401 cloud-auth error." Matches the
    /// `<red>Error: Ollama returned 401 Unauthorized.</red>` header used by both 401
    /// branches of <see cref="AIService.FormatHttpFailure"/> / <see cref="AIService.FormatErrorMessage"/>.
    /// </summary>
    private static bool Looks401(string responseText)
        => !string.IsNullOrEmpty(responseText)
           && responseText.Contains("401 Unauthorized", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Quick model-switch flow. Lists pulled models, lets the user pick one with
    /// cloud/local badges, then pipes them straight into the same context-size picker
    /// /config uses. Skips the rest of /config (temperature, timeout, ignore dirs) —
    /// those are reachable via /config as the final tip mentions.
    /// </summary>
    private async Task HandleModelCommandAsync()
    {
        var probe = await OllamaSetupHelper.ProbeAsync(Config.OllamaEndpoint);
        if (!probe.Ok)
        {
            AnsiConsole.MarkupLine($"[yellow]Can't reach Ollama at {Spectre.Console.Markup.Escape(Config.OllamaEndpoint)}.[/]");
            AnsiConsole.MarkupLine("[dim]Run /retry to reconnect, or /setup to walk through setup again.[/]");
            return;
        }

        var fetched = await OllamaSetupHelper.ListModelsWithStatusAsync(probe.NormalizedUrl);
        if (!fetched.Ok)
        {
            AnsiConsole.MarkupLine("[yellow]Couldn't fetch your model list.[/]");
            AnsiConsole.MarkupLine($"[dim]Details: {Spectre.Console.Markup.Escape(fetched.Error ?? "unknown error")}[/]");
            AnsiConsole.MarkupLine("[dim]Run /retry to reconnect, or /setup to walk through setup again.[/]");
            return;
        }
        if (fetched.Models.Count == 0)
        {
            AnsiConsole.MarkupLine("[yellow]No models pulled yet.[/]");
            AnsiConsole.MarkupLine("[dim]Run /setup to install a starter model.[/]");
            return;
        }

        // Same picker layout as /setup's PickModelAsync — cloud bubbles to top,
        // alphabetical otherwise, badge after each tag, single-space split for
        // the tag.
        AnsiConsole.Write(new Rule("[yellow]Pick a model[/]").LeftJustified());
        AnsiConsole.WriteLine();
        var labeled = fetched.Models
            .OrderBy(m => m.Contains(":cloud", StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ThenBy(m => m, StringComparer.OrdinalIgnoreCase)
            .Select(m => m.Contains(":cloud", StringComparison.OrdinalIgnoreCase)
                ? $"{m}   (cloud)"
                : $"{m}   (local)")
            .ToArray();

        var picked = AnsiConsole.Prompt(
            new SelectionPrompt<string>()
                .Title("[cyan]Select a model:[/]")
                .AddChoices(labeled));
        var modelTag = picked.Split(' ')[0];

        Config.ModelName = modelTag;
        Config.ModelPath = null;

        // Same context-size picker /config uses — k-notation labels, current value
        // highlighted at top, 200k/256k tiers for capable cloud models.
        AnsiConsole.WriteLine();
        Config.MaxTokens = ConfigurationWizard.ConfigureMaxTokens(Config.MaxTokens);

        Config.Save();
        await AI.ReinitializeAsync(Config);

        AnsiConsole.MarkupLine($"[green]✓ Now using {Spectre.Console.Markup.Escape(modelTag)} with {Config.MaxTokens / 1024}k max tokens.[/]");
        AnsiConsole.MarkupLine("[dim]Tip: run /config to tweak temperature, timeout, ignore dirs, or other settings.[/]");
        AnsiConsole.WriteLine();
    }

    /// <summary>
    /// Auto-launch the cloud sign-in walkthrough after a chat response surfaced a 401.
    /// Same flow as the menu inside /setup, but invoked inline so the user doesn't have
    /// to type /setup → re-pick the model → wait for the auth check just to reach the
    /// "Sign me in now" prompt they obviously need. Hides HomeView via _setupActive so
    /// the walkthrough's imperative output isn't overlapped by VDOM redraws.
    /// </summary>
    private async Task TryAutoSigninAfter401Async()
    {
        AnsiConsole.WriteLine();
        AnsiConsole.MarkupLine("[cyan]Launching sign-in walkthrough so you can fix this now...[/]");
        AnsiConsole.WriteLine();

        _setupActive = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var flow = new OnboardingFlow(
                setStatus: SetOnboardingStatus,
                promptTextVdom: (title, placeholder, validate, initialValue) => WizardPromptTextAsync(title, placeholder, validate, initialValue));

            var signedIn = await flow.WalkThroughCloudSigninAsync(Config.OllamaEndpoint);
            if (signedIn)
            {
                // Reinitialize the kernel against the (now-authenticated) daemon so
                // the next chat doesn't re-hit a stale connection.
                await AI.ReinitializeAsync(Config);
                AnsiConsole.WriteLine();
                AnsiConsole.MarkupLine("[green]✓ Signed in. Re-send your message to try again.[/]");
                AnsiConsole.WriteLine();
            }
        }
        finally
        {
            SetOnboardingStatus("");
            _setupActive = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Start MCP clients and attach their tools to the kernel. Failures per-server are
    /// surfaced via `/mcp` — a broken server never blocks the app from starting.
    /// </summary>
    private async Task InitializeMcpAsync()
    {
        if (!Config.EnableMcp || Config.McpServers.Count == 0) return;

        try
        {
            await McpManager.StartAllAsync();
            await AI.AttachMcpPluginsAsync();

            var active = McpManager.ActiveClients.Count;
            var failed = McpManager.StartupErrors.Count;
            if (active > 0 || failed > 0)
            {
                var summary = failed == 0
                    ? $"[dim]MCP: {active} server(s) connected.[/]"
                    : $"[dim]MCP: {active} connected, {failed} failed (type /mcp for details).[/]";
                AnsiConsole.MarkupLine(summary);
            }
        }
        catch (Exception ex)
        {
            AnsiConsole.MarkupLine($"[yellow]MCP startup error: {Spectre.Console.Markup.Escape(ex.Message)}[/]");
        }
    }

    private async Task ValidateCurrentModelAsync()
    {
        // Validate that model supports function calling
        var (isValid, errorMessage) = await AI.ValidateModelAsync();
        if (!isValid && errorMessage != null)
        {
            // Show warning but allow user to continue
            AnsiConsole.WriteLine();
            AnsiConsole.MarkupLine("[yellow]Warning:[/]");
            AnsiConsole.WriteLine(errorMessage);
            AnsiConsole.WriteLine();

            if (errorMessage.Contains("Continue anyway?"))
            {
                var continueAnyway = AnsiConsole.Confirm("Continue with this model?", false);
                if (!continueAnyway)
                {
                    AnsiConsole.WriteLine("Please configure a supported model:");
                    AnsiConsole.WriteLine("  mandocode --config set model qwen2.5-coder:14b");
                    AnsiConsole.WriteLine("  ollama pull qwen2.5-coder:14b");
                    ThemeService.ResetPalette();
                    ThemeService.Dispose();
                    Environment.Exit(1);
                    return;
                }
            }
            else
            {
                // Hard error (model not found) — enter limited mode
                _modelError = true;
                _modelWarning = errorMessage;
                AnsiConsole.WriteLine();
                AnsiConsole.MarkupLine("[yellow]You can fix this by:[/]");
                AnsiConsole.MarkupLine("[dim]  1. Pull the model:[/] ollama pull <model-name>");
                AnsiConsole.MarkupLine("[dim]  2. Run[/] /config [dim]to select a different model[/]");
                AnsiConsole.MarkupLine("[dim]  3. Make sure Ollama is running:[/] ollama serve");
                AnsiConsole.WriteLine();
            }
        }
        else
        {
            _modelError = false;
            _modelWarning = null;
        }
    }

    private void OnFunctionInvoked(FunctionCall call)
    {
        // Pause the spinner so the message renders on a clean line
        Spinner.Stop();

        // Track operation type for contextual spinner messages
        _lastOperationType = call.FunctionName.Replace("FileSystem_", "").ToLowerInvariant();

        // Suppress display for known FileSystem operations — they will be shown
        // as rich operation displays when OnFunctionCompleted fires
        if (!IsFileSystemOperation(call.FunctionName))
        {
            AnsiConsole.MarkupLine($"[dim][[Function]][/] [cyan]{Spectre.Console.Markup.Escape(call.Description)}[/]");
        }

        // Show what the model is doing above the spinner in grey
        Spinner.Start(call.Description);
    }

    private void OnFunctionCompleted(MandoCode.Models.FunctionExecutionResult result)
    {
        // Pause the spinner so the message renders on a clean line
        Spinner.Stop();

        if (result.OperationDisplay != null)
        {
            // Render directly to stdout (capture deferred to Phase 2)
            OperationRenderer.Render(result.OperationDisplay);

            // Track consecutive reads for contextual spinner messages
            if (result.OperationDisplay.OperationType == "Read")
            {
                _recentReadCount++;
                var fileName = Path.GetFileName(result.OperationDisplay.FilePath);
                if (!string.IsNullOrEmpty(fileName))
                    _recentReadFiles.Add(fileName);
            }
            else
            {
                // Non-read operation resets the read tracker
                _recentReadCount = 0;
                _recentReadFiles.Clear();
            }
        }
        else if (result.Success)
        {
            AnsiConsole.MarkupLine($"[dim][[Done]][/] [green]✓[/]");
        }
        else
        {
            AnsiConsole.MarkupLine($"[dim][[Error]][/] [red]{Spectre.Console.Markup.Escape(result.Result)}[/]");
        }

        // Refresh file cache after any operation that modifies the file system
        var fnLower = result.FunctionName.ToLowerInvariant();
        if (fnLower.Contains("write") || fnLower.Contains("delete") || fnLower.Contains("create") || fnLower.Contains("folder"))
        {
            FileProvider.RefreshCache();
        }

        // Show contextual spinner message based on what just happened
        var activity = GetContextualActivity(result);
        Spinner.Start(activity);
    }

    /// <summary>
    /// Generates a contextual activity message for the spinner based on recent operations.
    /// </summary>
    private string? GetContextualActivity(FunctionExecutionResult result)
    {
        var opType = result.OperationDisplay?.OperationType ?? _lastOperationType ?? "";

        return opType switch
        {
            "Read" when _recentReadCount >= 2 => $"Analyzing {_recentReadCount} files...",
            "Read" => "Analyzing file...",
            "Write" or "Update" => "Applying changes...",
            "Search" => "Reviewing search results...",
            "Glob" => "Scanning project structure...",
            "WebSearch" => "Processing search results...",
            "WebFetch" => "Reading web content...",
            "Delete" => "Continuing...",
            "Command" => "Processing command output...",
            _ => null
        };
    }

    /// <summary>
    /// Checks if a function name belongs to the FileSystem plugin.
    /// </summary>
    private bool IsFileSystemOperation(string functionName)
    {
        return functionName.StartsWith("FileSystem_", StringComparison.Ordinal);
    }

    private async Task<bool> CheckOllamaConnectionAsync()
    {
        var probe = await OllamaSetupHelper.ProbeAsync(Config.OllamaEndpoint);
        if (probe.WasHealed)
        {
            // /retry hit the slash bug — heal silently here too so the user doesn't have
            // to restart to clear the typo.
            Config.OllamaEndpoint = probe.NormalizedUrl;
            Config.Save();
        }
        return probe.Ok;
    }

    private async Task RunInteractiveLoopAsync()
    {
        while (true)
        {
            // Show session token count right-aligned above prompt
            if (Config.EnableTokenTracking && TokenTracker.TotalSessionTokens > 0)
            {
                var tokenDisplay = $"Total [{TokenTrackingService.FormatTokenCount(TokenTracker.TotalSessionTokens)} tokens]";
                var padding = Math.Max(0, Console.WindowWidth - tokenDisplay.Length - 1);
                Console.WriteLine($"\u001b[2m{new string(' ', padding)}{tokenDisplay}\u001b[0m");
            }

            // Ensure music visualizer is running if music is active
            // (it writes to a fixed upper-right screen position via ANSI escapes, no prompt conflict)
            StartMusicVisualizer();

            // Await user input via VDOM PromptInput component.
            var input = await WaitForVdomInputAsync();

            if (string.IsNullOrWhiteSpace(input))
                continue;

            // Echo the submitted input in gold so it persists in terminal scrollback.
            // The 100ms delay in WaitForVdomInputAsync ensures the VDOM repaint
            // (which removes PromptInput) has completed before this write.
            Console.Write($"\u001b[38;2;255;200;80m> {input}\u001b[0m");
            Console.WriteLine();

            // Shell escape: !<cmd> runs a shell command inline
            if (input.TrimStart().StartsWith('!'))
            {
                await Shell.HandleShellCommandAsync(input.TrimStart()[1..].Trim());
                continue;
            }

            // Check if this is a command (starts with /)
            if (InputStateMachine.IsCommand(input))
            {
                var command = InputStateMachine.GetCommandName(input);

                // Handle special commands
                if (command == "exit")
                {
                    StopMusicVisualizer();
                    MusicPlayer.Dispose();
                    ThemeService.Dispose();
                    AnsiConsole.WriteLine("Goodbye!");
                    Environment.Exit(0);
                    return;
                }

                if (command == "clear")
                {
                    await AI.ClearHistoryAsync();
                    StateMachine.ClearHistory();
                    Console.Clear();
                    AnsiConsole.WriteLine("Conversation cleared.");
                    continue;
                }

                if (command == "help")
                {
                    Console.WriteLine();
                    // Display help (we'll use direct Spectre.Console since HelpDisplay is a component)
                    var table = new Spectre.Console.Table()
                    {
                        Border = TableBorder.Rounded
                    };
                    table.AddColumn("Command");
                    table.AddColumn("Description");
                    table.AddRow("/help", "Show this help message");
                    table.AddRow("/setup", "Reconnect to Ollama or pick a different model (guided wizard)");
                    table.AddRow("/model", "Quick switch — pick a different model + context size");
                    table.AddRow("/config", "Adjust settings — model, temperature, max tokens, timeout, ignore dirs");
                    table.AddRow("/retry", "Retry Ollama connection");
                    table.AddRow("/learn", "Learn about LLMs and local AI models");
                    table.AddRow("/music", "Play lofi/synthwave coding music");
                    table.AddRow("/music-stop", "Stop music playback");
                    table.AddRow("/music-pause", "Pause/resume music");
                    table.AddRow("/music-next", "Skip to next track");
                    table.AddRow("/music-vol", "Set volume (0-100)");
                    table.AddRow("/music-lofi", "Switch to lofi genre");
                    table.AddRow("/music-synthwave", "Switch to synthwave genre");
                    table.AddRow("/music-list", "Show available tracks");
                    table.AddRow("/command", "Run a shell command (also: !<cmd>)");
                    table.AddRow("/copy", "Copy last AI response to clipboard");
                    table.AddRow("/copy-code", "Copy code blocks from last response");
                    table.AddRow("/skills", "List installed skills (auto-invoked when relevant)");
                    table.AddRow("/force-skill", "Override: force a specific skill to run now");
                    table.AddRow("/mcp", "List MCP servers with status and tool counts");
                    table.AddRow("/mcp add", "Interactively add a new MCP server");
                    table.AddRow("/mcp remove <name>", "Remove an MCP server from config");
                    table.AddRow("/mcp tools <server>", "List tools exposed by connected MCP servers (server optional)");
                    table.AddRow("/mcp-reload", "Restart MCP servers and re-register their tools");
                    table.AddRow("/clear", "Clear conversation history");
                    table.AddRow("/exit", "Exit MandoCode");
                    AnsiConsole.Write(table);
                    AnsiConsole.WriteLine();
                    AnsiConsole.WriteLine("Examples:");
                    AnsiConsole.WriteLine("  • What files are in this project?");
                    AnsiConsole.WriteLine("  • Show me the contents of Program.cs");
                    AnsiConsole.WriteLine("  • Refactor the Main method to use async/await");
                    AnsiConsole.WriteLine("  • What's the current git status?");
                    AnsiConsole.WriteLine();
                    continue;
                }

                if (command == "config")
                {
                    await HandleConfigCommandAsync();
                    continue;
                }

                if (command == "model")
                {
                    await HandleModelCommandAsync();
                    continue;
                }

                if (command == "setup")
                {
                    // Hide the HomeView component (static info + ready + help table)
                    // while the wizard runs imperatively — without this the VDOM
                    // redraws that block on top of the wizard's output every time
                    // SetOnboardingStatus fires StateHasChanged. forceInteractive
                    // ensures the wizard always shows visible UI rather than hitting
                    // the silent fast path, so users don't end up with a blank screen.
                    _setupActive = true;
                    await InvokeAsync(StateHasChanged);

                    try
                    {
                        await RunOnboardingFlowAsync(forceInteractive: true);
                    }
                    finally
                    {
                        _setupActive = false;
                    }

                    // Re-probe after the flow so /setup can also recover the connection state.
                    var probe = await OllamaSetupHelper.ProbeAsync(Config.OllamaEndpoint);
                    _isConnected = probe.Ok;
                    if (_isConnected)
                    {
                        await ValidateCurrentModelAsync();
                    }
                    await InvokeAsync(StateHasChanged);
                    continue;
                }

                if (command == "learn")
                {
                    await HandleLearnCommandAsync();
                    continue;
                }

                if (command == "retry")
                {
                    await HandleRetryCommandAsync();
                    continue;
                }

                if (command == "copy")
                {
                    HandleCopyCommand();
                    continue;
                }

                if (command == "copy-code")
                {
                    HandleCopyCodeCommand();
                    continue;
                }

                if (command == "rabbit")
                {
                    HandleRabbitCommand();
                    continue;
                }

                // Music commands
                if (command == "music")           { HandleMusicCommand("play"); continue; }
                if (command == "music-stop")      { HandleMusicCommand("stop"); continue; }
                if (command == "music-pause")     { HandleMusicCommand("pause"); continue; }
                if (command == "music-next")      { HandleMusicCommand("next"); continue; }
                if (command == "music-playlist")      { HandleMusicPlaySelection(); continue; }
                if (command == "music-list")      { HandleMusicCommand("list"); continue; }
                if (command.StartsWith("music-vol"))
                {
                    HandleMusicCommand(command);
                    continue;
                }

                if (command == "command" || command.StartsWith("command "))
                {
                    var shellCmd = command.Length > 7 ? command[8..].Trim() : "";
                    await Shell.HandleShellCommandAsync(shellCmd);
                    continue;
                }

                if (command == "skills")
                {
                    HandleSkillsListCommand();
                    continue;
                }

                if (command == "force-skill" || command.StartsWith("force-skill "))
                {
                    var skillName = command.Length > "force-skill".Length
                        ? command["force-skill".Length..].Trim()
                        : "";
                    await HandleForceSkillCommandAsync(skillName);
                    continue;
                }

                if (command == "mcp")
                {
                    await HandleMcpListCommandAsync();
                    continue;
                }

                if (command == "mcp add" || command.StartsWith("mcp add "))
                {
                    await HandleMcpAddCommandAsync();
                    continue;
                }

                if (command == "mcp remove" || command.StartsWith("mcp remove "))
                {
                    var serverArg = command.Length > "mcp remove".Length
                        ? command["mcp remove".Length..].Trim()
                        : "";
                    await HandleMcpRemoveCommandAsync(serverArg);
                    continue;
                }

                if (command == "mcp tools" || command.StartsWith("mcp tools "))
                {
                    var serverFilter = command.Length > "mcp tools".Length
                        ? command["mcp tools".Length..].Trim()
                        : null;
                    await HandleMcpToolsCommandAsync(string.IsNullOrWhiteSpace(serverFilter) ? null : serverFilter);
                    continue;
                }

                if (command == "mcp-reload")
                {
                    await HandleMcpReloadCommandAsync();
                    continue;
                }

                // Unknown command
                AnsiConsole.MarkupLine($"[red]Unknown command: {Spectre.Console.Markup.Escape(input)}[/]");
                AnsiConsole.MarkupLine("[dim]Type /help for available commands[/]");
                AnsiConsole.WriteLine();
                continue;
            }

            if (!_isConnected)
            {
                ShowOfflineGuidance();
                continue;
            }

            // Block AI requests when model is not available
            if (_modelError)
            {
                AnsiConsole.MarkupLine("[yellow]No model loaded.[/] Run [cyan]/config[/] to select a model, or pull one with [cyan]ollama pull <model-name>[/].");
                AnsiConsole.WriteLine();
                continue;
            }

            // Matrix easter egg: play a cinematic moment for trigger phrases
            if (ContainsMatrixTrigger(input))
            {
                PlayMatrixMoment(input);
            }

            // Check if this request needs task planning BEFORE injecting file content,
            // so that attached file size doesn't inflate the complexity heuristics
            var needsPlanning = TaskPlanner.RequiresPlanning(input);

            // Process @file references and inject file content
            var processedInput = ProcessFileReferences(input);

            // Add user message to chat history
            _messages.Add(new ChatMsg { Role = "user", Text = input });

            // Heuristic fallback: for models that don't reliably self-invoke propose_plan,
            // nudge them with a directive. The propose_plan call is still intercepted by
            // the filter and handed to the approval UI via PlanHandoff.
            if (needsPlanning)
            {
                processedInput += "\n\n[system: this request looks multi-step. " +
                                  "Call propose_plan now with the breakdown before doing any work.]";
            }

            // Process AI request with streaming (non-command input)
            await ProcessDirectRequestAsync(processedInput);
        }
    }

    /// <summary>
    /// Called by PromptInput when the user submits text via the VDOM TextInput.
    /// Completes the TaskCompletionSource so the interactive loop can continue.
    /// </summary>
