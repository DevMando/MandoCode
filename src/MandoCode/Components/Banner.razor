@using Spectre.Console;

@code {
    protected override void OnInitialized()
    {
        // Easter egg: 1-in-50 chance of a brief "Neo's monitor" glitch
        if (Random.Shared.Next(50) == 0)
        {
            PlayMatrixGlitch();
        }

        var version = typeof(Program).Assembly.GetName().Version;
        var versionStr = version != null ? $"v{version.Major}.{version.Minor}.{version.Build}" : "";
        var gradientText = BuildGradientBanner(versionStr);

        var panel = new Spectre.Console.Panel(new Spectre.Console.Markup("\n\n" + gradientText + "\n\n"));
        panel.Border(BoxBorder.Rounded);
        panel.BorderColor(Color.Teal);

        AnsiConsole.Write(panel);
    }

    // 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武
    //  Gradient MANDOCODE figlet text
    // 笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武笊絶武

    private static readonly string[] _figletLines =
    {
       @"    __  __        _        _   _    ____      ___      ____     ___     ____      _____    ",
       @" |#|  \/  |    /// \    |/| \ | | ||  _ \   // _ \   // ___|  // _ \  ||  _ \  |/| ____|   ",
       @" |#| |\/| |   /// _ \   |/|  \| | || | | | || | | | || |     || | | | || | | | |/|  _|     ",
       @" |#| |  | |  /// ___ \  |/| |\  | || |_| | || |_| | || |___  || |_| | || |_| | |/| |___    ",
       @" |#|_|  |_| ///_/   \_\ |/|_| \_| ||____/   \\___/   \\____|  \\___/  ||____/  |/|_____|   ",
       @" 笆鯛亦笆凪桝笆鯛亦笆凪亦笆鯛桝笆停俣笆鯛桝笆停俣笆停桝笆鯛亦笆凪桝笆鯛亦笆凪亦笆鯛桝笆停俣笆鯛桝笆停俣笆停桝笆鯛亦笆凪桝笆鯛亦笆凪亦笆鯛桝笆停俣笆鯛桝笆停俣笆停桝笆鯛亦笆凪桝笆鯛亦笆凪亦笆鯛桝笆停俣笆鯛亦笆凪亦笆鯛桝笆停俣笆鯛桝笆停俣笆停桝笆鯛亦笆凪桝        ",
       @" 笆凪桝笆停俣笆鯛桝笆鯛亦笆凪桝笆停桝笆鯛俣笆停桝笆鯛桝笆停俣笆鯛桝笆停桝笆凪桝笆鯛亦笆凪桝笆鯛亦笆鯛俣笆鯛桝笆停俣笆鯛桝笆停桝笆凪桝笆鯛亦笆凪桝笆鯛亦笆鯛俣笆鯛桝笆停俣笆鯛桝笆停桝笆凪桝笆鯛亦笆凪桝笆停俣笆鯛桝笆停桝笆凪桝笆鯛亦笆凪桝         "
    };

    // Gradient stops: teal -> cyan -> blue -> violet -> magenta
    private static readonly (int R, int G, int B)[] _gradientStops =
    {
        (0, 210, 178),
        (0, 200, 255),
        (60, 120, 255),
        (160, 80, 255),
        (210, 50, 210),
    };

    private static (int R, int G, int B) LerpColor(double t)
    {
        double pos = t * (_gradientStops.Length - 1);
        int idx = (int)pos;
        if (idx >= _gradientStops.Length - 1)
            return _gradientStops[^1];

        double frac = pos - idx;
        var a = _gradientStops[idx];
        var b = _gradientStops[idx + 1];

        return (
            (int)(a.R + (b.R - a.R) * frac),
            (int)(a.G + (b.G - a.G) * frac),
            (int)(a.B + (b.B - a.B) * frac)
        );
    }

    private static string BuildGradientBanner(string version)
    {
        int maxWidth = _figletLines.Max(l => l.Length);
        var sb = new System.Text.StringBuilder();

        for (int row = 0; row < _figletLines.Length; row++)
        {
            var line = _figletLines[row];

            for (int col = 0; col < line.Length; col++)
            {
                char c = line[col];

                if (c == ' ')
                {
                    sb.Append(' ');
                }
                else
                {
                    double t = maxWidth > 1 ? (double)col / (maxWidth - 1) : 0;
                    var (r, g, b) = LerpColor(t);

                    string ch = c switch
                    {
                        '[' => "[[",
                        ']' => "]]",
                        _ => c.ToString()
                    };
                    sb.Append($"[rgb({r},{g},{b})]{ch}[/]");
                }
            }

            if (row < _figletLines.Length - 1)
                sb.Append('\n');
        }

        // Version tag right-aligned under the figlet
        if (!string.IsNullOrEmpty(version))
        {
            var pad = Math.Max(0, maxWidth - version.Length);
            sb.Append('\n');
            sb.Append(new string(' ', pad));
            sb.Append($"[rgb(140,100,200)]{version}[/]");
        }

        return sb.ToString();
    }

    private static void PlayMatrixGlitch()
    {
        Console.Clear();
        Thread.Sleep(400);
        AnsiConsole.MarkupLine("[green]Wake up...[/]");
        Thread.Sleep(800);
        AnsiConsole.MarkupLine("[green]The Matrix has you...[/]");
        Thread.Sleep(800);
        AnsiConsole.MarkupLine("[green]Follow the white rabbit. 睡[/]");
        Thread.Sleep(1200);
        Console.Clear();
    }
}
