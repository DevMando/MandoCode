@using MandoCode.Models
@using MandoCode.Services
@using Spectre.Console

@* TextInput — the only component *@
<TextInput @bind-Value="_inputValue"
           OnInput="HandleInput"
           OnSubmit="HandleSubmit"
           Placeholder="@("type / for commands, @ for files")"
           ValueColor="@(new Color(255, 200, 80))"
           PlaceholderColor="Color.Grey"
           BorderColor="Color.Green"
           FocusedBorderColor="Color.Green"
           DisabledBorderColor="Color.Green"
           BorderStyle="BoxBorder.Double"
           Disabled="@Disabled"
           Expand="true"
           FocusOrder="0" />

@code {
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public EventCallback<string> OnAutocompleteRequested { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string InitialValue { get; set; } = "";

    [Inject] private InputStateMachine SM { get; set; } = default!;

    private string _inputValue = "";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(InitialValue))
        {
            _inputValue = InitialValue;
            InitialValue = ""; // Consume it so it doesn't re-apply on next render
        }
    }

    private async Task HandleInput(string value)
    {
        _inputValue = value;

        var action = SM.UpdateText(value);

        // When autocomplete triggers, hand off to imperative mode
        if (action == InputAction.ShowCommandDropdown || action == InputAction.ShowFileDropdown)
        {
            await OnAutocompleteRequested.InvokeAsync(value);
        }
    }

    private void HandleSubmit(string value)
    {
        if (Disabled) return;
        if (string.IsNullOrWhiteSpace(value)) return;

        SM.SubmitInput(value);

        var submitted = value;
        _inputValue = "";
        StateHasChanged();

        OnSubmit.InvokeAsync(submitted);
    }

    public void SetValue(string value)
    {
        _inputValue = value;
        StateHasChanged();
    }
}
