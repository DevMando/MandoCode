@using MandoCode.Models
@using MandoCode.Services
@using Spectre.Console

@* TextInput — the only component *@
<TextInput @bind-Value="_inputValue"
           OnInput="HandleInput"
           OnSubmit="HandleSubmit"
           Placeholder="@("type / for commands, @ for files")"
           ValueColor="@(new Color(255, 200, 80))"
           PlaceholderColor="Color.Grey"
           BorderColor="Color.Green"
           FocusedBorderColor="Color.Green"
           DisabledBorderColor="Color.Green"
           BorderStyle="BoxBorder.Double"
           Disabled="@Disabled"
           Expand="true"
           FocusOrder="0" />

@code {
    [Parameter] public EventCallback<string> OnSubmit { get; set; }
    [Parameter] public EventCallback<string> OnAutocompleteRequested { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string InitialValue { get; set; } = "";

    [Inject] private InputStateMachine SM { get; set; } = default!;

    private string _inputValue = "";
    private DateTime _lastInputAt = DateTime.MinValue;
    private int _lastLength = 0;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(InitialValue))
        {
            _inputValue = InitialValue;
            InitialValue = ""; // Consume it so it doesn't re-apply on next render
        }
    }

    // Paste handling: terminals stream paste as a burst of keystrokes, not a discrete event.
    // RazorConsole 0.5.0's single-line TextInput interprets pasted '\r' as Enter and fires
    // OnSubmit mid-paste, splitting the buffer. Two layers defend against that:
    //   A) sanitize '\r'/'\n'/'\t' to space here, push the cleaned value back via SetValue.
    //   B) HandleSubmit suppresses Submits that fire <30ms after the last OnInput —
    //      paste '\r' arrives <1ms after the prior char; human Enter is always >100ms.
    private async Task HandleInput(string value)
    {
        var sanitized = value;
        if (value.IndexOfAny(new[] { '\r', '\n', '\t' }) >= 0)
        {
            sanitized = value.Replace("\r\n", " ").Replace('\r', ' ').Replace('\n', ' ').Replace('\t', ' ');
            SetValue(sanitized);
        }

        _inputValue = sanitized;

        var action = SM.UpdateText(sanitized);

        _lastInputAt = DateTime.UtcNow;
        _lastLength = sanitized.Length;

        // When autocomplete triggers, hand off to imperative mode
        if (action == InputAction.ShowCommandDropdown || action == InputAction.ShowFileDropdown)
        {
            await OnAutocompleteRequested.InvokeAsync(sanitized);
        }
    }

    private void HandleSubmit(string value)
    {
        if (Disabled) return;
        if (string.IsNullOrWhiteSpace(value)) return;

        // Paste-burst guard: a Submit firing within 30ms of the last OnInput is the '\r'
        // from a paste burst, not a real user Enter. Humans can't reach Enter that fast.
        var sinceInput = (DateTime.UtcNow - _lastInputAt).TotalMilliseconds;
        if (sinceInput < 30)
        {
            SetValue(value);
            SM.UpdateText(value);
            return;
        }

        SM.SubmitInput(value);

        var submitted = value;
        _inputValue = "";
        _lastLength = 0;
        StateHasChanged();

        OnSubmit.InvokeAsync(submitted);
    }

    public void SetValue(string value)
    {
        _inputValue = value;
        StateHasChanged();
    }
}
